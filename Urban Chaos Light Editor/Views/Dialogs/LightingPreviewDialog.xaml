<Window x:Class="UrbanChaosLightEditor.Views.Dialogs.LightingPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="D3D Lighting Preview"
        Width="700" Height="420"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#2b2b2b">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Subtitle -->
        <TextBlock Grid.Row="0"
                   Text="Shows how the current D3D / Specular / Ambient settings affect a building surface."
                   Foreground="#888" FontSize="11" Margin="0,0,0,10"/>

        <!-- Side-by-side panes -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Original -->
            <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#444" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Original"
                               HorizontalAlignment="Center" Foreground="#888"
                               FontSize="11" Margin="0,6,0,6"/>
                    <Image Grid.Row="1" x:Name="ImgOriginal"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Stretch="Uniform" Margin="8"/>
                </Grid>
            </Border>

            <!-- D3D Lit -->
            <Border Grid.Column="2" Background="#1E1E1E" BorderBrush="#444" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="D3D Lit"
                               HorizontalAlignment="Center" Foreground="#888"
                               FontSize="11" Margin="0,6,0,6"/>
                    <Image Grid.Row="1" x:Name="ImgLit"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Stretch="Uniform" Margin="8"
                           Visibility="Collapsed"/>
                    <TextBlock Grid.Row="1" x:Name="TxtStatus"
                               Text="Rendering..." HorizontalAlignment="Center"
                               VerticalAlignment="Center" Foreground="#888"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Close -->
        <Button Grid.Row="2" Content="Close" Width="80" HorizontalAlignment="Right"
                Margin="0,10,0,0" Click="Close_Click"
                Background="#3A3D42" Foreground="White" BorderThickness="0" Padding="8,4"/>
    </Grid>
</Window>
