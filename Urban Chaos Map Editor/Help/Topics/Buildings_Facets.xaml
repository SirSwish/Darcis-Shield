        <Table.Columns>
            <TableColumn Width="120"/>
            <TableColumn Width="80"/>
            <TableColumn Width="120"/>
            <TableColumn Width="300"/>
        </Table.Columns>
        <TableRowGroup>
            <TableRow Background="#2A2D32">
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph FontWeight="Bold" Foreground="#7AD7FF">Facet Type</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph FontWeight="Bold" Foreground="#7AD7FF">Color</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph FontWeight="Bold" Foreground="#7AD7FF">Max Width</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph FontWeight="Bold" Foreground="#7AD7FF">Notes</Paragraph>
                </TableCell>
            </TableRow>
            <TableRow>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Walls</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph Foreground="#90EE90">Green</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Unlimited</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Textures stack vertically</Paragraph>
                </TableCell>
            </TableRow>
            <TableRow>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Ladders</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph Foreground="#FFA500">Orange</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>1 cell</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Only Height + Y Offset properties</Paragraph>
                </TableCell>
            </TableRow>
            <TableRow>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Fences</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph Foreground="#FFFF00">Yellow</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Unlimited</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Textures stretch to height</Paragraph>
                </TableCell>
            </TableRow>
            <TableRow>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Cables</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph Foreground="#FF6347">Red</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Unlimited</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Only facet type that can be diagonal</Paragraph>
                </TableCell>
            </TableRow>
            <TableRow>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph>Doors</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
                    <Paragraph Foreground="#DA70D6">Purple</Paragraph>
                </TableCell>
                <TableCell Padding="8,4" BorderBrush="#444" BorderThickness="1">
