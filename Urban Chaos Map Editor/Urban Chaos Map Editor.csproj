<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>UrbanChaosMapEditor</RootNamespace>
    <AssemblyName>UrbanChaosMapEditor</AssemblyName>
    <Version>1.13.0</Version>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\Icons\app.ico</ApplicationIcon>
  </PropertyGroup>

  <!-- 1) Remove any accidental None/Content items under Assets -->
  <ItemGroup>
    <Compile Remove="Assets\Images\NewFolder\**" />
    <EmbeddedResource Remove="Assets\Images\NewFolder\**" />
    <None Remove="Assets\**\*.*" />
    <None Remove="Assets\Images\NewFolder\**" />
    <Content Remove="Assets\**\*.*" />
  </ItemGroup>

  <!-- 2) Pack EVERYTHING under Assets as WPF Resource (pack://application:,,,/Assets/...) -->
  <ItemGroup>
    <Resource Include="Assets\**\*.*" />
  </ItemGroup>
  <ItemGroup>
    <Page Remove="Assets\Images\NewFolder\**" />
    <Resource Remove="Assets\Images\NewFolder\**" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="Help\Images\getting_started_coordinates.png" />
    <None Remove="Help\Images\getting_started_editor_drawer.png" />
    <None Remove="Help\Images\getting_started_editor_tabs.png" />
    <None Remove="Help\Images\getting_started_empty_canvas.png" />
    <None Remove="Help\Images\getting_started_menu_bar.png" />
