    <None Remove="Help\Images\getting_started_toolbar.png" />
    <None Remove="Help\Images\getting_started_zoom_controls.png" />
    <None Remove="Help\Images\heights_drag_area.png" />
    <None Remove="Help\Images\heights_editor_tab.png" />
    <None Remove="Help\Images\heights_layer_toggle.png" />
    <None Remove="Help\Images\heights_raise_lower_example.png" />
    <None Remove="Help\Images\heights_randomized.png" />
    <None Remove="Help\Images\heights_vertex_circles.png" />
    <None Remove="Help\Images\map_overview_buildings.png" />
    <None Remove="Help\Images\map_overview_height_vertices.png" />
    <None Remove="Help\Images\map_overview_prims.png" />
    <None Remove="Help\Images\map_overview_tile_grid.png" />
    <None Remove="Help\Images\map_overview_walkables_rf4.png" />
    <None Remove="Help\Images\textures_beta_checkbox.PNG" />
    <None Remove="Help\Images\textures_example_5x5.png" />
    <None Remove="Help\Images\textures_ghost_preview.png" />
    <None Remove="Help\Images\textures_rotation.png" />
    <None Remove="Help\Images\textures_world_selected.png" />
  </ItemGroup>
  <ItemGroup>
    <Page Remove="Help\Topics\Getting_Started.xaml" />
    <Page Remove="Help\Topics\Heights.xaml" />
    <Page Remove="Help\Topics\Map_Overview.xaml" />
    <Page Remove="Help\Topics\Textures.xaml" />
  </ItemGroup>

  <!-- (Optional) Keep these folders visible in Solution Explorer -->
  <ItemGroup>
    <ProjectReference Include="..\UrbanChaosEditor.Shared\UrbanChaosEditor.Shared.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Resource Update="Assets\Images\PrimGraphics\199.PNG">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Resource>
  </ItemGroup>
  <ItemGroup>
    <Resource Include="Help\Images\getting_started_coordinates.png" />
