<Window x:Class="UrbanChaosMapEditor.Views.Buildings.Dialogs.AddDoorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Door" 
        Width="400"
        SizeToContent="Height"
        Background="#202225"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Fg" Color="White"/>
        <SolidColorBrush x:Key="Subtle" Color="#FFB0B0B0"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2F3136"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3D42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="80"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4D52"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DrawButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#5865F2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6875F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Subtle}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Add Door to Building" 
                       FontWeight="Bold" 
                       FontSize="16"/>
            <TextBlock x:Name="TxtBuildingInfo"
                       Text="Building #0"
                       Foreground="{StaticResource Subtle}"
                       FontSize="12"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Y Height -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Y Offset (Quarter Storeys, 4 = 1 storey):" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtY0" Text="0" Width="100" HorizontalAlignment="Left"/>
            <TextBlock Text="Set to match the floor level where the door sits"
                       Foreground="{StaticResource Subtle}"
                       FontSize="10"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Draw on Map -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="Position:" Style="{StaticResource FieldLabel}"/>
            <Button x:Name="BtnDrawOnMap"
                    Content="Draw on Map"
                    Style="{StaticResource DrawButton}"
                    Click="BtnDrawOnMap_Click"
                    HorizontalAlignment="Left"
                    ToolTip="Click to draw the door segment on the map"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Cancel" 
                    Style="{StaticResource ActionButton}"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
