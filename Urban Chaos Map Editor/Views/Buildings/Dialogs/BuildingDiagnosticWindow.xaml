<Window x:Class="UrbanChaosMapEditor.Views.Buildings.Dialogs.BuildingDiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Building Diagnostics"
        Height="700"
        Width="900"
        Background="#222222"
        Foreground="White"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnFullReport" Content="Full Map Report" Click="BtnFullReport_Click" 
                    Padding="10,5" Margin="0,0,10,0" Background="#3a5a3a" Foreground="White"/>

            <TextBlock Text="Building A:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="TxtBuildingA" Width="50" Background="#333" Foreground="White" 
                     BorderBrush="#555" Padding="4,2" Text="1"/>

            <TextBlock Text="Building B:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="TxtBuildingB" Width="50" Background="#333" Foreground="White" 
                     BorderBrush="#555" Padding="4,2" Text="2"/>

            <Button x:Name="BtnCompare" Content="Compare Buildings" Click="BtnCompare_Click" 
                    Padding="10,5" Margin="10,0,0,0" Background="#3a3a5a" Foreground="White"/>

            <Button x:Name="BtnSingleBuilding" Content="Single Building" Click="BtnSingleBuilding_Click" 
                    Padding="10,5" Margin="10,0,0,0" Background="#5a3a3a" Foreground="White"/>
        </StackPanel>

        <!-- Output -->
        <Border Grid.Row="1" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Background="#111">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="TxtOutput" 
                         IsReadOnly="True" 
                         Background="Transparent" 
                         Foreground="#ddd" 
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="BtnCopy" Content="Copy to Clipboard" Click="BtnCopy_Click" 
                    Padding="10,5" Background="#444" Foreground="White"/>
            <Button x:Name="BtnSaveToFile" Content="Save to File" Click="BtnSaveToFile_Click" 
                    Padding="10,5" Margin="10,0,0,0" Background="#444" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
