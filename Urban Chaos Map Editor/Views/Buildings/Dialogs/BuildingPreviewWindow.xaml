<Window x:Class="UrbanChaosMapEditor.Views.Buildings.Dialogs.BuildingPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Building Editor"
        SizeToContent="WidthAndHeight"
        MinWidth="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#222222"
        TextElement.Foreground="White"
        Foreground="White">

    <Window.DataContext>
        <Binding RelativeSource="{RelativeSource Self}" Mode="OneWay" />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ReadOnlyBox" TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#888888"/>
        </Style>
        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
    </Window.Resources>

    <Border Padding="16" Background="#222222" BorderBrush="#444" BorderThickness="1" CornerRadius="6">
        <StackPanel>
            <!-- Header -->
            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,2">
                <Run Text="Building #"/>
                <Run Text="{Binding BuildingId1, Mode=OneWay}"/>
            </TextBlock>
            <TextBlock x:Name="TxtTypeDisplay" FontSize="12" Foreground="#AAA" Margin="0,0,0,8"/>

            <Separator Margin="0,4,0,10"/>

            <!-- Facet Range (read-only  managed by BuildingAdder/Deleter) -->
            <TextBlock Text="FACET RANGE" FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Start:"/>
                <TextBox Grid.Column="1" Style="{StaticResource ReadOnlyBox}" Width="60"
                         Text="{Binding Building.StartFacet, Mode=OneWay}"/>
                <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="End:"/>
                <TextBox Grid.Column="4" Style="{StaticResource ReadOnlyBox}" Width="60"
                         Text="{Binding Building.EndFacet, Mode=OneWay}"/>
                <TextBlock Grid.Column="5" Style="{StaticResource InfoText}">
                    <Run Text="("/>
                    <Run Text="{Binding FacetCount, Mode=OneWay}"/>
                    <Run Text=" facets, 1-based exclusive)"/>
                </TextBlock>
            </Grid>

            <!-- World Position -->
            <TextBlock Text="WORLD POSITION" FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="X:"/>
                <TextBox Grid.Column="1" x:Name="TxtWorldX" Style="{StaticResource FieldBox}"
                         Text="{Binding EditWorldX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="Y:"/>
                <TextBox Grid.Column="4" x:Name="TxtWorldY" Style="{StaticResource FieldBox}"
                         Text="{Binding EditWorldY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="6" Style="{StaticResource FieldLabel}" Text="Z:"/>
                <TextBox Grid.Column="7" x:Name="TxtWorldZ" Style="{StaticResource FieldBox}"
                         Text="{Binding EditWorldZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- Type -->
            <TextBlock Text="TYPE" FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Type:"/>
                <ComboBox Grid.Column="1" x:Name="CmbType" Width="140"
                          Background="#333" Foreground="White" BorderBrush="#555"
                          SelectionChanged="CmbType_SelectionChanged"/>
                <TextBlock Grid.Column="2" Style="{StaticResource InfoText}"
                           Text="0=House, 1=Warehouse, 2=Office, 3=Apartment"/>
            </Grid>

            <!-- Walkable + Ware -->
            <TextBlock Text="REFERENCES" FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Walkable:"/>
                <TextBox Grid.Column="1" x:Name="TxtWalkable" Style="{StaticResource FieldBox}" Width="60"
                         Text="{Binding EditWalkable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="Ware:"/>
                <TextBox Grid.Column="4" x:Name="TxtWare" Style="{StaticResource FieldBox}" Width="60"
                         Text="{Binding EditWare, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="5" Style="{StaticResource InfoText}"
                           Text="Walkable=DWalkable index (0=none). Ware=WARE_ware[] index."/>
            </Grid>

            <!-- Counters + Padding -->
            <TextBlock Text="COUNTERS / PADDING" FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Cnt0:"/>
                <TextBox Grid.Column="1" x:Name="TxtCounter0" Style="{StaticResource FieldBox}" Width="50"
                         Text="{Binding EditCounter0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="3" Style="{StaticResource FieldLabel}" Text="Cnt1:"/>
                <TextBox Grid.Column="4" x:Name="TxtCounter1" Style="{StaticResource FieldBox}" Width="50"
                         Text="{Binding EditCounter1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="6" Style="{StaticResource FieldLabel}" Text="Pad:"/>
                <TextBox Grid.Column="7" x:Name="TxtPadding" Style="{StaticResource FieldBox}" Width="50"
                         Text="{Binding EditPadding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <Separator Margin="0,4,0,8"/>

            <!-- Raw bytes dump -->
            <Expander Header="Raw bytes (24 bytes)" IsExpanded="False" Margin="0,0,0,8"
                      Foreground="White">
                <StackPanel>
                    <TextBlock Opacity="0.7" Margin="0,4,0,6" FontSize="11">
                        <Run Text="File offset: "/><Run Text="{Binding RawBytesOffsetHex, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,4"
                               Text="+0:SF +2:EF +4:X(S32) +8:Y(S24) +11:Type +12:Z(S32) +16:Walk +18:Cnt[2] +20:Pad +22:Ware +23:(unused)"/>
                    <TextBox Text="{Binding RawBytesHex, Mode=OneWay}"
                             FontFamily="Consolas" FontSize="12"
                             Background="#0E0E0E" Foreground="White"
                             BorderBrush="#333" BorderThickness="1"
                             Padding="6" IsReadOnly="True"
                             TextWrapping="Wrap" Height="40"/>
                </StackPanel>
            </Expander>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button Content="Apply" Width="80" Margin="0,0,8,0"
                        Click="BtnApply_Click" ToolTip="Write changes to the map file buffer"/>
                <Button Content="Close" Width="80" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
