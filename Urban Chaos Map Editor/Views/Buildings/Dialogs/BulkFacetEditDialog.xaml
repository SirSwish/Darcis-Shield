<Window x:Class="UrbanChaosMapEditor.Views.Buildings.Dialogs.BulkFacetEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Facet Edit"
        Width="500"
        SizeToContent="Height"
        Background="#202225"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Fg"     Color="White"/>
        <SolidColorBrush x:Key="Subtle" Color="#FFB0B0B0"/>
        <SolidColorBrush x:Key="Sep"    Color="#333333"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2D32"/>
            <Setter Property="BorderBrush" Value="#4A4D52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="64"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Uniformity symbol for numeric fields: = (green) or ≠ (orange) -->
        <Style x:Key="UniformSym" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,2,0"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Uniformity symbol for individual flags: tiny, sits beside checkbox -->
        <Style x:Key="FlagSym" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>

        <Style x:Key="PickBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3D42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4D52"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ApplyBtn" TargetType="Button">
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4A52D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6875F3"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3D42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4D52"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAB0BB"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Fields -->
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>  <!-- Flags -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────── -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="TxtTitle"
                       FontSize="15"
                       FontWeight="Bold"
                       Text="Bulk Facet Edit"/>
            <TextBlock x:Name="TxtSubtitle"
                       Foreground="{StaticResource Subtle}"
                       FontSize="11"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Fields ────────────────────────────────────────── -->
        <!--
            Column layout per row:
              Col 0 (20)  — enable checkbox
              Col 1 (106) — label
              Col 2 (*)   — input controls + uniformity symbol + hint
        -->
        <Border Grid.Row="2"
                Background="#252830"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeader}" Text="Values to apply"/>

                <!-- Y0 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="106"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ChkApplyY0" Grid.Column="0" IsChecked="True"/>
                    <TextBlock Grid.Column="1" Text="Y Offset (Y0)" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBox x:Name="TxtY0" Style="{StaticResource FieldBox}"
                                 IsEnabled="{Binding IsChecked, ElementName=ChkApplyY0}"/>
                        <TextBlock x:Name="SymY0" Style="{StaticResource UniformSym}"/>
                        <TextBlock Style="{StaticResource HintText}" Text="Base altitude offset (signed)"/>
                    </StackPanel>
                </Grid>

                <!-- Height -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="106"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ChkApplyHeight" Grid.Column="0" IsChecked="True"/>
                    <TextBlock Grid.Column="1" Text="Height" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBox x:Name="TxtHeight" Style="{StaticResource FieldBox}"
                                 IsEnabled="{Binding IsChecked, ElementName=ChkApplyHeight}"/>
                        <TextBlock x:Name="SymHeight" Style="{StaticResource UniformSym}"/>
                        <TextBlock Style="{StaticResource HintText}" Text="¼-storey  (4 = 1 floor)"/>
                    </StackPanel>
                </Grid>

                <!-- BlockHeight -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="106"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ChkApplyBlockHeight" Grid.Column="0" IsChecked="True"/>
                    <TextBlock Grid.Column="1" Text="Block Height" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBox x:Name="TxtBlockHeight" Style="{StaticResource FieldBox}"
                                 IsEnabled="{Binding IsChecked, ElementName=ChkApplyBlockHeight}"/>
                        <TextBlock x:Name="SymBlockHeight" Style="{StaticResource UniformSym}"/>
                        <TextBlock Style="{StaticResource HintText}" Text="4 px each  (16 = 1 floor)"/>
                    </StackPanel>
                </Grid>

                <!-- Base Style -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="106"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ChkApplyStyle" Grid.Column="0" IsChecked="True"/>
                    <TextBlock Grid.Column="1" Text="Base Style" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBox x:Name="TxtStyle" Style="{StaticResource FieldBox}"
                                 IsEnabled="{Binding IsChecked, ElementName=ChkApplyStyle}"/>
                        <Button x:Name="BtnPickStyle"
                                Content="Pick..."
                                Style="{StaticResource PickBtn}"
                                IsEnabled="{Binding IsChecked, ElementName=ChkApplyStyle}"
                                Click="BtnPickStyle_Click"/>
                        <TextBlock x:Name="SymStyle" Style="{StaticResource UniformSym}"/>
                        <TextBlock Style="{StaticResource HintText}" Text="TMA style number"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Flags ─────────────────────────────────────────── -->
        <!--
            Each flag is tri-state:
              Checked      = force ON  for all facets
              Unchecked    = force OFF for all facets
              Indeterminate = leave unchanged  (seeded when values are mixed)
            The small symbol beside each checkbox shows = (uniform) or ≠ (mixed).
        -->
        <Border Grid.Row="4"
                Background="#252830"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Flags" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Foreground="#666" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"
                               Text="Indeterminate (—) = leave unchanged"/>
                </StackPanel>

                <UniformGrid Columns="4">
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagInvisible"   Content="Invisible"   IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagInvisible"   Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagInside"      Content="Inside"      IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagInside"      Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagDlit"        Content="Dlit"        IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagDlit"        Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagHugFloor"    Content="HugFloor"    IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagHugFloor"    Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagElectrified" Content="Electrified" IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagElectrified" Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagTwoSided"    Content="TwoSided"    IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagTwoSided"    Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagUnclimbable" Content="Unclimbable" IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagUnclimbable" Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagOnBuilding"  Content="OnBuilding"  IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagOnBuilding"  Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagBarbTop"     Content="BarbTop"     IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagBarbTop"     Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagSeeThrough"  Content="SeeThrough"  IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagSeeThrough"  Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagOpen"        Content="Open"        IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagOpen"        Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagDeg90"       Content="Deg90"       IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagDeg90"       Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagTwoTextured" Content="TwoTextured" IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagTwoTextured" Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <CheckBox x:Name="FlagFenceCut"    Content="FenceCut"    IsThreeState="True"/>
                        <TextBlock x:Name="SymFlagFenceCut"    Style="{StaticResource FlagSym}"/>
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- ── Buttons ───────────────────────────────────────── -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="BtnCancel"
                    Content="Cancel"
                    Style="{StaticResource CancelBtn}"
                    Click="BtnCancel_Click"
                    Margin="0,0,8,0"/>
            <Button x:Name="BtnApply"
                    Content="Apply to All"
                    Style="{StaticResource ApplyBtn}"
                    Click="BtnApply_Click"/>
        </StackPanel>
    </Grid>
</Window>
