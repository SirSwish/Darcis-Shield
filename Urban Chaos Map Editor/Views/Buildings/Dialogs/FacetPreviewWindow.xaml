<Window x:Class="UrbanChaosMapEditor.Views.Buildings.Dialogs.FacetPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Facet Editor" Width="960" Height="680"
        Background="#202225"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        ResizeMode="CanResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Fg" Color="White"/>
        <SolidColorBrush x:Key="Subtle" Color="#FFB0B0B0"/>
        <SolidColorBrush x:Key="EditableBg" Color="#2A2D32"/>
        <SolidColorBrush x:Key="EditableBorder" Color="#4A4D52"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        </Style>

        <Style TargetType="ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{StaticResource Fg}"/>
        </Style>

        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="#333"/>
        </Style>

        <Style x:Key="EditableField" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource EditableBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource EditableBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Subtle}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3D42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="WhiteCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="260" MaxWidth="380"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Properties -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Facet Editor" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <!-- Identity -->
                <Border BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Identity" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="FacetIdText" Margin="0,6,0,0"/>
                        <TextBlock x:Name="FacetTypeText" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Coordinates -->
                <Border BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Coordinates" FontWeight="Bold" FontSize="14"/>
                        <StackPanel x:Name="CoordPanel" Margin="0,6,0,0"/>

                        <Button x:Name="BtnRedraw"
                                Content="✏️ Redraw on Map"
                                Margin="0,10,0,0"
                                Style="{StaticResource ActionButton}"
                                Click="BtnRedraw_Click"
                                ToolTip="Redraw this facet on the map. First click = start vertex, second click = end vertex. Right-click cancels."/>
                    </StackPanel>
                </Border>

                <!-- Height -->
                <Border BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Height" FontWeight="Bold" FontSize="14"/>
                        <StackPanel x:Name="HeightPanel" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Flags -->
                <Border BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Flags" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="FacetFlagsText" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        <ItemsControl x:Name="FlagsList" Margin="0,6,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource WhiteCheckBox}"
                                              Content="{Binding Name}"
                                              IsChecked="{Binding IsSet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Tag="{Binding Bit}"
                                              Margin="0,2,12,2"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Style section (Face A / primary) -->
                <Border BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="StyleSectionLabel" Text="Style" FontWeight="Bold" FontSize="14"/>

                        <TextBlock x:Name="StyleModeText" Margin="0,6,0,0"/>
                        <TextBlock x:Name="BaseStyleText" Margin="0,4,0,0"/>

                        <Expander Header="Advanced" Margin="0,8,0,0">
                            <StackPanel Margin="0,6,0,0">
                                <TextBlock x:Name="AdvancedDStoreyText" Margin="0,0,0,4"/>
                                <TextBlock x:Name="AdvancedDStyleText" Margin="0,0,0,4"/>
                                <TextBlock x:Name="AdvancedPaintMemIndexText" Margin="0,0,0,4"/>
                                <TextBlock x:Name="AdvancedPaintMemCountText" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="DStorey:" Foreground="#AAA" VerticalAlignment="Center" Width="60"/>
                                    <TextBox x:Name="TxtDStorey" Width="60"
                                             Background="#333" Foreground="White" BorderBrush="#555"
                                             Padding="4,2" HorizontalContentAlignment="Right"
                                             ToolTip="Index into InsideStorey[]. 0 = no indoor association."/>
                                    <Button Content="Apply" Padding="6,2" Margin="6,0,0,0"
                                            Click="BtnApplyDStorey_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- Legacy hidden controls kept for compatibility -->
                        <TextBlock x:Name="RecipeText" Visibility="Collapsed"/>
                        <StackPanel x:Name="RawStylePanel" Visibility="Collapsed"/>
                        <StackPanel x:Name="PaintedPanel" Visibility="Collapsed">
                            <TextBlock x:Name="RawStyleText" Visibility="Collapsed"/>
                            <TextBlock x:Name="PaintedSummaryText" Visibility="Collapsed"/>
                            <TextBlock x:Name="PaintBytesHexText" Visibility="Collapsed"/>
                            <DataGrid x:Name="PaintBytesGrid" Visibility="Collapsed"/>
                        </StackPanel>

                        <Button x:Name="BtnPaintFacet" 
                                Content="🎨 Paint Facet..." 
                                Margin="0,10,0,0"
                                Style="{StaticResource ActionButton}"
                                Click="BtnPaintFacet_Click"
                                ToolTip="Open the texture painter to paint individual cells of this facet."/>

                        <Button x:Name="BtnChangeStyle"
                                Content="🧩 Change Style..."
                                Margin="0,8,0,0"
                                Style="{StaticResource ActionButton}"
                                Click="BtnChangeStyle_Click"
                                ToolTip="Select a new raw TMA style for this facet."/>
                    </StackPanel>
                </Border>

                <!-- Face B / Second Face Style -->
                <Border x:Name="SecondFacePanel"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="SecondFaceSectionLabel" Text="Face B Style (Interior)" FontWeight="Bold" FontSize="14"/>

                        <TextBlock x:Name="SecondFaceStyleModeText" Margin="0,6,0,0"/>
                        <TextBlock x:Name="SecondFaceBaseStyleText" Margin="0,4,0,0"/>

                        <Expander Header="Advanced" Margin="0,8,0,0">
                            <StackPanel Margin="0,6,0,0">
                                <TextBlock x:Name="SecondFaceAdvancedDStoreyText" Margin="0,0,0,4"/>
                                <TextBlock x:Name="SecondFaceAdvancedDStyleText" Margin="0,0,0,4"/>
                                <TextBlock x:Name="SecondFaceAdvancedPaintMemIndexText" Margin="0,0,0,4"/>
                                <TextBlock x:Name="SecondFaceAdvancedPaintMemCountText" Margin="0,0,0,8"/>
                                <TextBlock Text="Face B DStorey editing: edit via Face A (shared field)."
                                           Foreground="#666" FontSize="10" FontStyle="Italic"/>
                            </StackPanel>
                        </Expander>

                        <!-- Legacy hidden controls kept for compatibility -->
                        <TextBlock x:Name="SecondFaceRecipeText" Visibility="Collapsed"/>
                        <StackPanel x:Name="SecondFaceRawPanel" Visibility="Collapsed"/>
                        <StackPanel x:Name="SecondFacePaintedPanel" Visibility="Collapsed">
                            <TextBlock x:Name="SecondFaceRawStyleText" Visibility="Collapsed"/>
                            <TextBlock x:Name="SecondFacePaintedSummaryText" Visibility="Collapsed"/>
                            <TextBlock x:Name="SecondFacePaintHexText" Visibility="Collapsed"/>
                        </StackPanel>

                        <Button x:Name="BtnChangeSecondFaceStyle"
                                Content="🧩 Change Face B Style..."
                                Margin="0,8,0,0"
                                Style="{StaticResource ActionButton}"
                                Click="BtnChangeSecondFaceStyle_Click"
                                ToolTip="Select a new TMA style for the second face (interior/back)."/>

                        <Button x:Name="BtnPaintFaceB"
                                Content="🎨 Paint Side B..."
                                Margin="0,8,0,0"
                                Style="{StaticResource ActionButton}"
                                Click="BtnPaintFaceB_Click"
                                ToolTip="Open the texture painter for the secondary (inner) face of this facet."/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Tip: Use 'Redraw on Map' to interactively reposition the facet. First click = start, second click = end. Right-click cancels."
                           Foreground="{StaticResource Subtle}"
                           TextWrapping="Wrap"
                           FontSize="11"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1"/>

        <!-- RIGHT: Visual preview -->
        <Border Grid.Column="2" BorderThickness="1" CornerRadius="6" Padding="8">
            <ScrollViewer x:Name="PreviewScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#1E1F22">
                <StackPanel>

                    <!-- Side A -->
                    <Border BorderBrush="#3A3D42" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,12">
                        <Grid MinHeight="260">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="FaceALabel"
                                       Grid.Row="0"
                                       Text="Side A"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,0,0,2"
                                       HorizontalAlignment="Left"
                                       TextAlignment="Left"/>

                            <TextBlock x:Name="FaceASubLabel"
                                       Grid.Row="1"
                                       Text="Primary face"
                                       Foreground="#FFB0B0B0"
                                       FontSize="11"
                                       Margin="0,0,0,8"
                                       HorizontalAlignment="Left"
                                       TextAlignment="Left"/>

                            <Grid Grid.Row="2"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                                <Grid HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Canvas x:Name="PanelCanvas"
                                            Background="#202225"
                                            SnapsToDevicePixels="True"
                                            ClipToBounds="True"/>
                                    <Canvas x:Name="GridCanvas"
                                            IsHitTestVisible="False"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Side B -->
                    <Border BorderBrush="#3A3D42" BorderThickness="1" CornerRadius="6" Padding="8">
                        <Grid MinHeight="260">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="FaceBLabel"
                                       Grid.Row="0"
                                       Text="Side B"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,0,0,2"
                                       HorizontalAlignment="Left"
                                       TextAlignment="Left"/>

                            <TextBlock x:Name="FaceBSubLabel"
                                       Grid.Row="1"
                                       Text="Second / reverse face"
                                       Foreground="#FFB0B0B0"
                                       FontSize="11"
                                       Margin="0,0,0,8"
                                       HorizontalAlignment="Left"
                                       TextAlignment="Left"/>

                            <Grid Grid.Row="2"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                                <Grid x:Name="FaceBPreviewGrid"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Canvas x:Name="FaceBPanelCanvas"
                                            Background="#202225"
                                            SnapsToDevicePixels="True"
                                            ClipToBounds="True"/>
                                    <Canvas x:Name="FaceBGridCanvas"
                                            IsHitTestVisible="False"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>