<Window x:Class="UrbanChaosMapEditor.Views.Buildings.Dialogs.FacetSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Facet"
        Width="700"
        Height="300"
        WindowStartupLocation="CenterOwner"
        Background="#202225">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Multiple facets were found here. Select one:"
                   Foreground="White"
                   Margin="0,0,0,10"/>

        <ListBox x:Name="CandidatesList"
         Grid.Row="1"
         ItemsSource="{Binding Candidates}"
         DisplayMemberPath="Display"
         MouseDoubleClick="CandidatesList_MouseDoubleClick"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="OK" Width="90" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Cancel" Width="90" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>