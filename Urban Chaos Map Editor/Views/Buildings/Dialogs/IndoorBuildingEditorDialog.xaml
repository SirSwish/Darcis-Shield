<Window x:Class="UrbanChaosMapEditor.Views.Buildings.Dialogs.IndoorBuildingEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Indoor Building Editor" 
        Height="750" Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="RowBackground" Value="#2D2D30"/>
            <Setter Property="AlternatingRowBackground" Value="#333337"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3F3F46"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="5,3"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Building Selection -->
        <GroupBox Grid.Row="0" Header="Building Selection" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Building ID:" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtBuildingId" Grid.Column="1" Text="49" Background="#333" Foreground="White" BorderBrush="#555"/>
                <Button x:Name="btnLoad" Grid.Column="2" Content="Load" Width="60" Margin="10,0,0,0" Click="BtnLoad_Click"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Text="Status:" Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtStatus" Text="Not loaded" Foreground="Yellow" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <Button x:Name="btnListType1" Grid.Column="4" Content="List Type=1 Buildings" Width="140" Click="BtnListType1_Click"/>
            </Grid>
        </GroupBox>

        <!-- Building Summary -->
        <GroupBox Grid.Row="1" Header="Building Summary" Margin="0,0,0,10" x:Name="grpSummary">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Type:" Foreground="Gray"/>
                    <TextBlock x:Name="txtType" Text="-" Foreground="White" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Facets:" Foreground="Gray"/>
                    <TextBlock x:Name="txtFacets" Text="-" Foreground="White" FontSize="14"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="DStoreys Owned:" Foreground="Gray"/>
                    <TextBlock x:Name="txtStoreys" Text="-" Foreground="White" FontSize="14"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Negative dstyles Used:" Foreground="Gray"/>
                    <TextBlock x:Name="txtNegDStyles" Text="-" Foreground="White" FontSize="14"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Tabs for different views -->
        <TabControl Grid.Row="2" Background="#252526" BorderBrush="#3F3F46">
            <TabItem Header="DStoreys" Foreground="Black">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <CheckBox x:Name="chkShowAllStoreys" Content="Show all storeys (not just this building)" 
                                  Foreground="White" VerticalAlignment="Center"
                                  Checked="ChkShowAllStoreys_Changed" Unchecked="ChkShowAllStoreys_Changed"/>
                    </StackPanel>

                    <DataGrid x:Name="dgStoreys" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="60"/>
                            <DataGridTextColumn Header="Style" Binding="{Binding Style}" Width="60"/>
                            <DataGridTextColumn Header="PaintIdx" Binding="{Binding PaintIndex}" Width="60"/>
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="60"/>
                            <DataGridTextColumn Header="Padding" Binding="{Binding Padding}" Width="70"/>
                            <DataGridTextColumn Header="Ref'd by dstyles" Binding="{Binding ReferencesDisplay}" Width="150"/>
                            <DataGridTextColumn Header="Facet Count" Binding="{Binding UsedByFacets.Count}" Width="80"/>
                            <DataGridTextColumn Header="Offset" Binding="{Binding FileOffset, StringFormat=0x{0:X}}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                        <Button x:Name="btnAddStorey" Content="Add DStorey..." Width="100" Margin="0,0,5,0" Click="BtnAddStorey_Click"/>
                        <Button x:Name="btnEditStorey" Content="Edit Selected..." Width="100" Margin="0,0,5,0" Click="BtnEditStorey_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="dstyles (Storey Refs)" Foreground="Black">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                        <CheckBox x:Name="chkShowOnlyNegative" Content="Show only negative (storey refs)" 
                                  Foreground="White" VerticalAlignment="Center" IsChecked="True"
                                  Checked="ChkShowOnlyNegative_Changed" Unchecked="ChkShowOnlyNegative_Changed"/>
                        <CheckBox x:Name="chkShowOnlyUsed" Content="Show only used by this building" 
                                  Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"
                                  Checked="ChkShowOnlyUsed_Changed" Unchecked="ChkShowOnlyUsed_Changed"/>
                    </StackPanel>

                    <DataGrid x:Name="dgDStyles" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Index" Binding="{Binding Index}" Width="70"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="70"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeDisplay}" Width="80"/>
                            <DataGridTextColumn Header="Storey #" Binding="{Binding StoreyIndex}" Width="70"/>
                            <DataGridTextColumn Header="Used by Facets" Binding="{Binding UsedByFacets.Count}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                        <Button x:Name="btnAddNegDStyle" Content="Add Storey Ref..." Width="120" Margin="0,0,5,0" Click="BtnAddNegDStyle_Click"/>
                        <Button x:Name="btnEditDStyle" Content="Edit Selected..." Width="100" Margin="0,0,5,0" Click="BtnEditDStyle_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Facets ? dstyles Chain" Foreground="Black">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgFacetChain" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Facet #" Binding="{Binding FacetId}" Width="60"/>
                            <DataGridTextColumn Header="H" Binding="{Binding Height}" Width="40"/>
                            <DataGridTextColumn Header="FH" Binding="{Binding FHeight}" Width="40"/>
                            <DataGridTextColumn Header="FadeLevel" Binding="{Binding FadeLevel}" Width="80"/>
                            <DataGridTextColumn Header="dstyles[]" Binding="{Binding DStyleValue}" Width="70"/>
                            <DataGridTextColumn Header="Storey #" Binding="{Binding StoreyIndex}" Width="70"/>
                            <DataGridTextColumn Header="S.Style" Binding="{Binding StoreyStyle}" Width="60"/>
                            <DataGridTextColumn Header="S.PaintIdx" Binding="{Binding StoreyPaintIndex}" Width="70"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                        <Button x:Name="btnEditFacetFade" Content="Edit FadeLevel..." Width="120" Margin="0,0,5,0" Click="BtnEditFacetFade_Click"/>
                        <TextBlock Text="? Facets with positive dstyles won't render interior textures properly" 
                                   Foreground="Orange" VerticalAlignment="Center" Margin="20,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Walkables + RF4" Foreground="Black">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgWalkables" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Walkable #" Binding="{Binding Id}" Width="80"/>
                            <DataGridTextColumn Header="Bounds" Binding="{Binding BoundsDisplay}" Width="150"/>
                            <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="50"/>
                            <DataGridTextColumn Header="StoreyY" Binding="{Binding StoreyY}" Width="70"/>
                            <DataGridTextColumn Header="RF4 Range" Binding="{Binding RF4RangeDisplay}" Width="100"/>
                            <DataGridTextColumn Header="RF4 Count" Binding="{Binding RF4Count}" Width="70"/>
                            <DataGridTextColumn Header="Next" Binding="{Binding Next}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                        <Button Content="Add Walkable..." Width="100" Margin="0,0,5,0" IsEnabled="False" ToolTip="Use Buildings tab"/>
                        <Button Content="Paint RF4 Tiles..." Width="120" Margin="0,0,5,0" Click="BtnPaintRF4_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnFixBuilding" Content="?? Auto-Fix Indoor Building..." Width="180" Margin="0,0,10,0" 
                    Click="BtnFixBuilding_Click" ToolTip="Attempt to automatically create missing storey references"/>
            <Button x:Name="btnClose" Content="Close" Width="80" IsCancel="True" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
