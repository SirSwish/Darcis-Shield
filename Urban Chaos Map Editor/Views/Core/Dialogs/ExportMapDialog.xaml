<Window x:Class="UrbanChaosMapEditor.Views.Core.Dialogs.ExportMapDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Map — Select Layers"
        SizeToContent="Height" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#222222" Foreground="White">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Choose which layers to include in the export:"
                   Margin="0,0,0,10"
                   FontSize="13"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Map" FontWeight="SemiBold" Margin="0,4,0,4" Foreground="#BBBBBB"/>
            <CheckBox x:Name="ChkTextures"          Content="Textures"             Margin="8,2"/>
            <CheckBox x:Name="ChkRoofTextureOverlay" Content="Roof Texture Overlay" Margin="8,2"/>
            <CheckBox x:Name="ChkGridLines"         Content="Grid Lines"           Margin="8,2"/>
            <CheckBox x:Name="ChkMapWho"            Content="MapWho"               Margin="8,2"/>

            <TextBlock Text="Terrain" FontWeight="SemiBold" Margin="0,8,0,4" Foreground="#BBBBBB"/>
            <CheckBox x:Name="ChkHeights"  Content="Heights"   Margin="8,2"/>
            <CheckBox x:Name="ChkPapFlags" Content="PAP Flags" Margin="8,2"/>

            <TextBlock Text="Prims" FontWeight="SemiBold" Margin="0,8,0,4" Foreground="#BBBBBB"/>
            <CheckBox x:Name="ChkPrimGraphics" Content="Object Graphics" Margin="8,2"/>
            <CheckBox x:Name="ChkPrims"        Content="Objects"         Margin="8,2"/>

            <TextBlock Text="Buildings" FontWeight="SemiBold" Margin="0,8,0,4" Foreground="#BBBBBB"/>
            <CheckBox x:Name="ChkBuildings" Content="Buildings" Margin="8,2"/>

            <TextBlock Text="Roofs" FontWeight="SemiBold" Margin="0,8,0,4" Foreground="#BBBBBB"/>
            <CheckBox x:Name="ChkWalkables"      Content="Walkables"       Margin="8,2"/>
            <CheckBox x:Name="ChkRoofs"          Content="Roof Tiles"      Margin="8,2"/>
            <CheckBox x:Name="ChkRoofAltitudes"  Content="Roof Altitudes"  Margin="8,2"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,12">
            <Button Content="Select All"  Width="90" Margin="0,0,8,0" Click="SelectAll_Click"/>
            <Button Content="Select None" Width="90" Click="SelectNone_Click"/>
        </StackPanel>

        <Border Grid.Row="3"
                BorderBrush="#404040" BorderThickness="0,1,0,0"
                Padding="0,10,0,10" Margin="0,0,0,4">
            <StackPanel>
                <TextBlock Text="Output" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#BBBBBB"/>

                <StackPanel Orientation="Horizontal" Margin="8,2">
                    <TextBlock Text="Resolution:" Width="100" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbResolution" Width="180" SelectedIndex="0">
                        <ComboBoxItem Content="Full — 8192 × 8192"     Tag="8192"/>
                        <ComboBoxItem Content="Half — 4096 × 4096"     Tag="4096"/>
                        <ComboBoxItem Content="Quarter — 2048 × 2048"  Tag="2048"/>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="ChkDropAlpha"
                          Content="Drop alpha channel (smaller PNG, white background)"
                          IsChecked="True"
                          Margin="8,8,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Export" Width="80" Margin="0,0,8,0" IsDefault="True" Click="Export_Click"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
