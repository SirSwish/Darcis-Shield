<Window x:Class="UrbanChaosMapEditor.Views.Dialogs.PapHiCellEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PAP_HI Cell Editor"
        Width="640" Height="740"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1E1E1E">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox" x:Key="EditBox">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ReadOnlyBox" BasedOn="{StaticResource EditBox}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#FF252528"/>
            <Setter Property="Foreground" Value="#FF9CDCFE"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FF569CD6"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Coordinate input + navigation -->
        <GroupBox Grid.Row="0" Header="Cell Coordinates (Game Space — matches walkable X/Z)">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtGameX" Style="{StaticResource EditBox}" Text="0"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Z:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtGameZ" Style="{StaticResource EditBox}" Text="0"/>
                <Button Grid.Row="0" Grid.Column="6" Content="Load" Click="BtnLoad_Click" Width="60" IsDefault="True"/>

                <!-- Arrow navigation -->
                <StackPanel Grid.Row="0" Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="◄" Click="BtnLeft_Click" Width="28" ToolTip="X-1"/>
                    <Button Content="▲" Click="BtnUp_Click" Width="28" ToolTip="Z-1"/>
                    <Button Content="▼" Click="BtnDown_Click" Width="28" ToolTip="Z+1"/>
                    <Button Content="►" Click="BtnRight_Click" Width="28" ToolTip="X+1"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="9" x:Name="TxtFileInfo"
                           Foreground="#FF808080" FontFamily="Consolas" FontSize="11" Margin="0,4,0,0"
                           Text="Enter coordinates and click Load"/>
            </Grid>
        </GroupBox>

        <!-- Row 1: Raw bytes -->
        <GroupBox Grid.Row="1" Header="Raw Bytes (6 bytes — PAP_Hi struct)">
            <StackPanel>
                <TextBox x:Name="TxtRawHex" Style="{StaticResource ReadOnlyBox}" FontSize="16" FontWeight="Bold"
                         TextAlignment="Center" Text="-- -- -- -- -- --"/>
                <TextBlock Text="Tex0 Tex1 Flg0 Flg1  Hgt  Alt"
                           FontFamily="Consolas" FontSize="10" Foreground="#FF808080"
                           TextAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Row 2: Parsed fields -->
        <GroupBox Grid.Row="2" Header="Editable Fields">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Texture (u16):" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTexture" Style="{StaticResource EditBox}"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Flags (hex u16):" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtFlagsHex" Style="{StaticResource EditBox}" TextChanged="TxtFlagsHex_TextChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Height (s8):" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtHeight" Style="{StaticResource EditBox}"/>
                <TextBlock Grid.Row="2" Grid.Column="5" x:Name="TxtHeightWorld" Foreground="#FF808080" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="3" Text="Alt (s8):" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="4" x:Name="TxtAlt" Style="{StaticResource EditBox}"/>
                <TextBlock Grid.Row="4" Grid.Column="3" Grid.ColumnSpan="3" x:Name="TxtAltWorld" Foreground="#FF808080" FontSize="11"/>
            </Grid>
        </GroupBox>

        <!-- Row 3: Flags checkboxes -->
        <GroupBox Grid.Row="3" Header="PAP_HI Flags (checkboxes sync with hex field above)">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <CheckBox x:Name="ChkShadow1"    Content="Bit 0  (0x0001) Shadow1"     Tag="0"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkShadow2"    Content="Bit 1  (0x0002) Shadow2"     Tag="1"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkShadow3"    Content="Bit 2  (0x0004) Shadow3"     Tag="2"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkReflective" Content="Bit 3  (0x0008) Reflective"  Tag="3"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkHidden"     Content="Bit 4  (0x0010) HIDDEN"      Tag="4"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"
                              FontWeight="Bold" Foreground="#FFFFCC00"/>
                    <CheckBox x:Name="ChkSinkSquare" Content="Bit 5  (0x0020) SinkSquare"  Tag="5"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkSinkPoint"  Content="Bit 6  (0x0040) SinkPoint"   Tag="6"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkNoUpper"    Content="Bit 7  (0x0080) NoUpper"     Tag="7"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <CheckBox x:Name="ChkNoGo"       Content="Bit 8  (0x0100) NoGo"        Tag="8"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkRoofExists" Content="Bit 9  (0x0200) ROOF_EXISTS" Tag="9"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"
                              FontWeight="Bold" Foreground="#FFFFCC00"/>
                    <CheckBox x:Name="ChkZone1"      Content="Bit 10 (0x0400) Zone1"       Tag="10" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkZone2"      Content="Bit 11 (0x0800) Zone2"       Tag="11" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkZone3"      Content="Bit 12 (0x1000) Zone3"       Tag="12" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkZone4"      Content="Bit 13 (0x2000) Zone4"       Tag="13" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkFlatRoof"   Content="Bit 14 (0x4000) FLAT_ROOF"   Tag="14" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"
                              FontWeight="Bold" Foreground="#FFFFCC00"/>
                    <CheckBox x:Name="ChkWater"      Content="Bit 15 (0x8000) Water"       Tag="15" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Row 4: Context info -->
        <GroupBox Grid.Row="4" Header="Context (Walkable / RF4 coverage at this cell)">
            <TextBox x:Name="TxtContext" Style="{StaticResource ReadOnlyBox}"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     Height="60" VerticalScrollBarVisibility="Auto"
                     Text="Load a cell to see context."/>
        </GroupBox>

        <!-- Row 5: Batch tools -->
        <GroupBox Grid.Row="5" Header="Batch Tools — apply to rectangular region (game coords, inclusive)">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="X1:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Grid.Column="1" x:Name="TxtBatchX1" Style="{StaticResource EditBox}"/>
                    <TextBlock Grid.Column="2" Text="  Z1:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Grid.Column="3" x:Name="TxtBatchZ1" Style="{StaticResource EditBox}"/>
                    <TextBlock Grid.Column="4" Text="  X2:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Grid.Column="5" x:Name="TxtBatchX2" Style="{StaticResource EditBox}"/>
                    <TextBlock Grid.Column="6" Text="  Z2:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Grid.Column="7" x:Name="TxtBatchZ2" Style="{StaticResource EditBox}"/>
                </Grid>
                <WrapPanel Margin="0,6,0,0">
                    <Button Content="Set Hidden+RoofExists" Click="BtnBatchSetHiddenRoof_Click"
                            ToolTip="ORs flags 0x0010 | 0x0200 on all cells in range"/>
                    <Button Content="Clear Hidden+RoofExists" Click="BtnBatchClearHiddenRoof_Click"
                            ToolTip="Clears flags 0x0010 | 0x0200 on all cells in range"/>
                    <Button Content="Set Alt from field" Click="BtnBatchSetAlt_Click"
                            ToolTip="Writes the Alt value above to all cells in range"/>
                    <Button Content="Copy flags from loaded" Click="BtnBatchCopyFlags_Click"
                            ToolTip="Copies the currently loaded Flags word to all cells in range"/>
                </WrapPanel>
                <TextBlock x:Name="TxtBatchStatus" Foreground="#FF4EC9B0" FontSize="11" Margin="0,4,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Row 6: Action buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Apply to this cell" Click="BtnApply_Click" FontWeight="Bold"
                    Background="#FF0E639C" Width="130"/>
            <Button Content="Close" Click="BtnClose_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
