<Window x:Class="UrbanChaosMapEditor.Views.Heights.Dialogs.HeightStampCreatorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Height Stamp Creator"
        Width="560" Height="560"
        MinWidth="400" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1E1E1E">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="3,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="CellBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="BorderBrush" Value="#FF404040"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="2,2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Stamp Name:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtStampName" Width="200" Text="My Stamp"/>
        </StackPanel>

        <!-- Size + Generate row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Width:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox x:Name="TxtWidth" Width="40" Text="5" TextAlignment="Center"
                     PreviewTextInput="Size_PreviewTextInput"/>
            <TextBlock Text="Height:" VerticalAlignment="Center" Margin="12,0,6,0"/>
            <TextBox x:Name="TxtHeight" Width="40" Text="5" TextAlignment="Center"
                     PreviewTextInput="Size_PreviewTextInput"/>
            <Button Content="Generate Grid" Margin="12,0,0,0" Click="GenerateGrid_Click"
                    ToolTip="Create or resize the editor grid (existing values are preserved where possible)"/>
        </StackPanel>

        <!-- Cell editor grid -->
        <Border Grid.Row="2" BorderBrush="#FF404040" BorderThickness="1"
                Background="#FF252526" CornerRadius="3">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="TxtGridHint"
                               Text="Click 'Generate Grid' to create the editor."
                               Foreground="#FF808080" Margin="8" TextWrapping="Wrap"/>
                    <ItemsControl x:Name="GridRows">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each "row" is a WrapPanel of TextBoxes -->
                                <ItemsControl ItemsSource="{Binding}"
                                              Margin="4,1">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource CellBox}"
                                                     ToolTip="{Binding ToolTip}"
                                                     PreviewTextInput="Cell_PreviewTextInput"
                                                     GotFocus="Cell_GotFocus"
                                                     LostFocus="Cell_LostFocus"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Buttons row -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock x:Name="TxtStatus" Foreground="#FF4EC9B0" VerticalAlignment="Center"
                       Margin="0,0,12,0" FontSize="11"/>
            <Button Content="Save Stamp" Click="SaveStamp_Click"
                    ToolTip="Save this stamp to the CustomStamps folder and add it to the library"/>
            <Button Content="Cancel" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
