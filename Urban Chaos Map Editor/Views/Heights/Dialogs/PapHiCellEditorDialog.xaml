<Window x:Class="UrbanChaosMapEditor.Views.Heights.Dialogs.PapHiCellEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cell Flags Editor"
        Width="420" Height="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1E1E1E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cell info -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="TxtCellInfo" Text="Cell (0, 0)" FontWeight="Bold" FontSize="14"
                       Foreground="#FF7AD7FF"/>
            <TextBlock x:Name="TxtFlagsHexDisplay" Text="Flags: 0x0000" FontFamily="Consolas"
                       Foreground="#FF808080" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Flags checkboxes -->
        <Border Grid.Row="1" Background="#FF252528" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <CheckBox x:Name="ChkShadow1"    Content="Shadow1"    Tag="0"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkShadow2"    Content="Shadow2"    Tag="1"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkShadow3"    Content="Shadow3"    Tag="2"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkReflective" Content="Reflective" Tag="3"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkHidden"     Content="Hidden"     Tag="4"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed" FontWeight="Bold"/>
                    <CheckBox x:Name="ChkSinkSquare" Content="SinkSquare" Tag="5"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkSinkPoint"  Content="SinkPoint"  Tag="6"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkNoUpper"    Content="NoUpper"    Tag="7"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <CheckBox x:Name="ChkNoGo"       Content="NoGo"       Tag="8"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkRoofExists" Content="RoofExists" Tag="9"  Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed" FontWeight="Bold"/>
                    <CheckBox x:Name="ChkZone1"      Content="Zone1"      Tag="10" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkZone2"      Content="Zone2"      Tag="11" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkZone3"      Content="Zone3"      Tag="12" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkZone4"      Content="Zone4"      Tag="13" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                    <CheckBox x:Name="ChkFlatRoof"   Content="FlatRoof"   Tag="14" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed" FontWeight="Bold"/>
                    <CheckBox x:Name="ChkWater"      Content="Water"      Tag="15" Checked="FlagCheckBox_Changed" Unchecked="FlagCheckBox_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="Close" Click="BtnClose_Click" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
