<Window x:Class="UrbanChaosMapEditor.Views.Help.HelpViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Urban Chaos Map Editor &#8212; Help" Width="1100" Height="800"
        Background="#1E1F22"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <SolidColorBrush x:Key="HelpBackground" Color="#1E1F22"/>
        <SolidColorBrush x:Key="HelpForeground" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#2A2D32"/>
        <SolidColorBrush x:Key="SidebarHover" Color="#3A3D42"/>
        <SolidColorBrush x:Key="SidebarSelected" Color="#3D5A80"/>
        <SolidColorBrush x:Key="AccentGold" Color="#FFD700"/>

        <Style x:Key="TocItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarSelected}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="180" MaxWidth="360"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar: Table of Contents -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sidebar header -->
                <Border Grid.Row="0" Background="#252830" Padding="14,12">
                    <TextBlock Text="Help Topics" FontWeight="Bold" FontSize="15"
                               Foreground="{StaticResource AccentGold}"/>
                </Border>

                <!-- Search box -->
                <Border Grid.Row="1" Padding="8,6">
                    <TextBox x:Name="TxtSearch" 
                             Background="#1E1F22" Foreground="#E0E0E0" 
                             BorderBrush="#444" BorderThickness="1"
                             Padding="6,4" FontSize="12"
                             TextChanged="TxtSearch_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Tag" Value="Search topics..."/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- Topic list -->
                <ListBox x:Name="TopicList" Grid.Row="2"
                         Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource TocItem}"
                         SelectionChanged="TopicList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="3" Background="#333"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"/>

        <!-- Content: FlowDocument viewer -->
        <Border Grid.Column="2" Background="{StaticResource HelpBackground}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Breadcrumb / current topic -->
                <Border Grid.Row="0" Background="#252830" Padding="14,8">
                    <TextBlock x:Name="TxtBreadcrumb" FontSize="12" Foreground="#808080"
                               Text="Select a topic from the sidebar"/>
                </Border>

                <!-- Document viewer -->
                <FlowDocumentScrollViewer x:Name="DocViewer" Grid.Row="1"
                                          Background="{StaticResource HelpBackground}"
                                          Foreground="{StaticResource HelpForeground}"
                                          VerticalScrollBarVisibility="Auto"
                                          IsToolBarVisible="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
