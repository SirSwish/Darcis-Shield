<Window x:Class="UrbanChaosMapEditor.Views.Prims.Dialogs.PrimPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prim Properties"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="#2b2b2b"
        Foreground="White"
        ResizeMode="NoResize">
    <Window.Resources>
        <!-- Checkbox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="16"
                                    Height="16"
                                    Background="Black"
                                    BorderBrush="White"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M0,4 L2,6 6,0"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"
                                      Margin="4,4,0,0"/>
                            </Border>
                            <ContentPresenter Margin="6,0,0,0"
                                              VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="90"/>
        </Style>

        <!-- One tile only -->
        <ImageBrush x:Key="WallBrush"
                    TileMode="None"
                    Stretch="Fill"/>
    </Window.Resources>

    <Grid Margin="12" Width="430">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- FLAGS + INSIDE -->
        <StackPanel Grid.Row="0" Orientation="Vertical">
            <TextBlock Text="Flags" FontWeight="SemiBold" Margin="0,0,0,6"/>

            <UniformGrid Columns="2" Rows="4" Margin="0,0,0,8">
                <CheckBox Content="On floor"    IsChecked="{Binding OnFloor}"/>
                <CheckBox Content="Searchable"  IsChecked="{Binding Searchable}"/>

                <CheckBox Content="Not on PSX"  IsChecked="{Binding NotOnPsx}"/>
                <CheckBox Content="Damaged"     IsChecked="{Binding Damaged}"/>

                <CheckBox Content="Warehouse (Inside)"   IsChecked="{Binding Warehouse}"/>
                <CheckBox Content="Hidden item" IsChecked="{Binding HiddenItem}"/>

                <CheckBox Content="Reserved 1"  IsChecked="{Binding Reserved1}"/>
                <CheckBox Content="Reserved 2"  IsChecked="{Binding Reserved2}"/>
            </UniformGrid>
        </StackPanel>

        <!-- HEIGHT -->
        <Border Grid.Row="2"
                Background="#252525"
                BorderBrush="#444"
                BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- One tile high visual -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="Height"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <Border BorderBrush="#444"
                            BorderThickness="1"
                            Padding="4"
                            HorizontalAlignment="Center">
                        <Canvas x:Name="Wall"
                                Width="64"
                                Height="64"
                                Background="{StaticResource WallBrush}"
                                MouseLeftButtonDown="Wall_MouseLeftButtonDown"
                                MouseMove="Wall_MouseMove"
                                MouseLeftButtonUp="Wall_MouseLeftButtonUp"
                                MouseWheel="Wall_MouseWheel">
                            <Ellipse x:Name="Dot"
                                     Width="8"
                                     Height="8"
                                     Fill="Red"
                                     Stroke="Black"
                                     StrokeThickness="1"/>
                        </Canvas>
                    </Border>

                    <TextBlock Text="Drag = offset, wheel = storey"
                               FontSize="11"
                               Opacity="0.75"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Height controls -->
                <StackPanel Grid.Column="2" VerticalAlignment="Top">
                    <TextBlock Text="Manual Height" FontWeight="SemiBold"/>
                    <TextBox x:Name="HeightTextBox"
                             Margin="0,6,0,0"
                             Width="120"
                             HorizontalAlignment="Left"
                             PreviewKeyDown="HeightTextBox_PreviewKeyDown"
                             LostFocus="HeightTextBox_LostFocus"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="-256"
                                Width="58"
                                Margin="0,0,6,0"
                                Click="MinusStorey_Click"/>
                        <Button Content="+256"
                                Width="58"
                                Click="PlusStorey_Click"/>
                    </StackPanel>

                    <Button x:Name="BtnSnapToFloor"
                            Content="Snap to Floor"
                            Width="120"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Click="SnapToFloor_Click"/>

                    <StackPanel Margin="0,12,0,0">
                        <TextBlock><Run Text="Storey: "/><Run x:Name="LblStorey"/></TextBlock>
                        <TextBlock Margin="0,4,0,0"><Run Text="Offset: "/><Run x:Name="LblOffset"/><Run Text=" px"/></TextBlock>
                        <TextBlock Margin="0,4,0,0"><Run Text="Total: "/><Run x:Name="LblTotal"/><Run Text=" px"/></TextBlock>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Style="{StaticResource DialogButton}"
                    Content="OK"
                    IsDefault="True"
                    Click="Ok_Click"/>
            <Button Style="{StaticResource DialogButton}"
                    Content="Cancel"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>