<Window x:Class="UrbanChaosMapEditor.Views.Roofs.Dialogs.AddWalkableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Walkable Region"
        Width="420"
        SizeToContent="Height"
        Background="#202225"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="Fg" Color="White"/>
        <SolidColorBrush x:Key="Subtle" Color="#FFB0B0B0"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2F3136"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#3A3D42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="80"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4D52"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#2D5A27"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D7A37"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Subtle}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Add Walkable Region"
                       FontWeight="Bold"
                       FontSize="16"/>
            <TextBlock x:Name="TxtBuilding"
                       Foreground="{StaticResource Subtle}"
                       FontSize="12"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Bounds info -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Tile Bounds:" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtBounds" Foreground="{StaticResource Subtle}" Margin="0,0,0,8"/>
            <TextBlock Text="Size:" Style="{StaticResource FieldLabel}"/>
            <TextBlock x:Name="TxtSize" Foreground="{StaticResource Subtle}"/>
        </StackPanel>

        <!-- Height -->
        <StackPanel Grid.Row="4">
            <TextBlock Text="World Y:" Style="{StaticResource FieldLabel}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBox x:Name="TxtWorldY"
                         Width="80"
                         PreviewTextInput="SignedNumericOnly_PreviewTextInput"
                         TextChanged="TxtWorldY_TextChanged"/>
                <TextBlock Text="256 = 1 floor"
                           Foreground="{StaticResource Subtle}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>
            <TextBlock x:Name="TxtInfo"
                       Foreground="{StaticResource Subtle}"
                       FontSize="11"
                       FontStyle="Italic"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Help text -->
        <TextBlock Grid.Row="6"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource Subtle}"
                   FontSize="10"
                   Text="The walkable region defines the roof surface characters can walk on. Set the height to match the top of the building's walls."/>

        <!-- Buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource ActionButton}"
                    Click="BtnCancel_Click"
                    Margin="0,0,8,0"/>
            <Button Content="Add Walkable"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnOk_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
