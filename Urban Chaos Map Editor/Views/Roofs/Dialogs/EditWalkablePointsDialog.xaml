<Window x:Class="UrbanChaosMapEditor.Views.Roofs.Dialogs.EditWalkablePointsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Walkable Points" 
        Height="340" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#2D2D30">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Edit Walkable Prim Point Range" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

        <!-- Info Panel -->
        <Border Grid.Row="1" Background="#252526" CornerRadius="4" Padding="8" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="TxtWalkableInfo" Text="Walkable #0 in Building #0" FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtFileOffset" Text="File Offset: 0x0000" Foreground="#888" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Current Values -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="StartPoint:" Margin="0,0,8,4"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtStartPoint" Margin="0,0,16,4"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="EndPoint:" Margin="0,0,8,4"/>
            <TextBox Grid.Row="0" Grid.Column="3" x:Name="TxtEndPoint" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" x:Name="TxtPointCount" 
                       Text="Point Count: 0" Foreground="#888" FontSize="11" Margin="0,4,0,0"/>
        </Grid>

        <!-- Quick Actions -->
        <GroupBox Grid.Row="3" Header="Quick Actions" BorderBrush="#555" Foreground="#E0E0E0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="8">
                <Button Content="Zero Both" Click="BtnZeroBoth_Click" ToolTip="Set StartPoint=0, EndPoint=0 (for testing)"/>
                <Button Content="Copy From..." Click="BtnCopyFrom_Click" ToolTip="Copy values from another walkable"/>
            </StackPanel>
        </GroupBox>

        <!-- Warning -->
        <Border Grid.Row="4" Background="#553300" CornerRadius="4" Padding="8">
            <TextBlock TextWrapping="Wrap" Foreground="#FFCC00">
                ?? WARNING: Changing these values may break roof rendering. 
                These indices reference runtime-generated prim_points. 
                Use this for TESTING only to confirm if non-zero values are required.
            </TextBlock>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Apply" Click="BtnApply_Click" IsDefault="True"/>
            <Button Content="Cancel" Click="BtnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
