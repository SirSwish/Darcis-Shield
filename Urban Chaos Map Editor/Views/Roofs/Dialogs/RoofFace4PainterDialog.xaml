<Window x:Class="UrbanChaosMapEditor.Views.Roofs.Dialogs.RoofFace4PainterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paint Roof Tiles" 
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">
    <Window.Resources>
        <Style x:Key="CellButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header info -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Walkable #" Foreground="White" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtWalkableId" Text="124" Foreground="Cyan" FontWeight="Bold" Margin="5,0,20,0" VerticalAlignment="Center"/>
            <TextBlock Text="Building #" Foreground="White" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtBuildingId" Text="49" Foreground="Cyan" FontWeight="Bold" Margin="5,0,20,0" VerticalAlignment="Center"/>
            <TextBlock Text="Bounds:" Foreground="White" VerticalAlignment="Center"/>
            <TextBlock x:Name="txtBounds" Text="(111,86) ? (119,93)" Foreground="Yellow" Margin="5,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Roof settings -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Altitude (QS):" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="txtAltitude" Grid.Column="1" Text="12" Background="#333" Foreground="White" BorderBrush="#555"/>
            <TextBlock Grid.Column="8" Text="Quarter Storeys (1 QS = 64 raw)" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>

            <TextBlock Grid.Column="2" Text="DY0 (SW):" Foreground="White" VerticalAlignment="Center" Margin="15,0,5,0"
                       ToolTip="SW corner delta — corner1 = SE + (DY0 &lt;&lt; ROOF_SHIFT)"/>
            <TextBox x:Name="txtDY0" Grid.Column="3" Text="0" Background="#333" Foreground="White" BorderBrush="#555"/>

            <TextBlock Grid.Column="4" Text="DY1 (NW):" Foreground="White" VerticalAlignment="Center" Margin="15,0,5,0"
                       ToolTip="NW corner delta — corner2 = SE + (DY1 &lt;&lt; ROOF_SHIFT)"/>
            <TextBox x:Name="txtDY1" Grid.Column="5" Text="0" Background="#333" Foreground="White" BorderBrush="#555"/>

            <TextBlock Grid.Column="6" Text="DY2 (NE):" Foreground="White" VerticalAlignment="Center" Margin="15,0,5,0"
                       ToolTip="NE corner delta — corner3 = SE + (DY2 &lt;&lt; ROOF_SHIFT)"/>
            <TextBox x:Name="txtDY2" Grid.Column="7" Text="0" Background="#333" Foreground="White" BorderBrush="#555"/>
        </Grid>

        <!-- Grid of cells -->
        <Border Grid.Row="2" BorderBrush="#555" BorderThickness="1" Background="#222">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="gridCells" Margin="10"/>
            </ScrollViewer>
        </Border>

        <!-- Legend and tools -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,10">
            <Border Background="#4CAF50" Width="20" Height="20" Margin="0,0,5,0"/>
            <TextBlock Text="Has RF4" Foreground="White" VerticalAlignment="Center" Margin="0,0,20,0"/>

            <Border Background="#333333" Width="20" Height="20" BorderBrush="#555" BorderThickness="1" Margin="0,0,5,0"/>
            <TextBlock Text="Empty" Foreground="White" VerticalAlignment="Center" Margin="0,0,30,0"/>

            <Button x:Name="btnSelectAll" Content="Select All" Width="80" Margin="0,0,5,0" Click="BtnSelectAll_Click"/>
            <Button x:Name="btnSelectNone" Content="Clear All" Width="80" Margin="0,0,5,0" Click="BtnSelectNone_Click"/>
            <Button x:Name="btnInvert" Content="Invert" Width="60" Click="BtnInvert_Click"/>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnApply" Content="Apply Changes" Width="120" Height="30" Margin="0,0,10,0" 
                    Background="#4CAF50" Foreground="White" Click="BtnApply_Click"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="80" Height="30" IsCancel="True" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
