<Window x:Class="UrbanChaosMapEditor.Views.Roofs.Dialogs.RoofFace4PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roof Tile Editor"
        Height="680"
        Width="680"
        Background="#222222"
        Foreground="White"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="80"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="InfoText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
        <Style x:Key="FlagCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="130"/>
        </Style>
    </Window.Resources>

    <!-- Outer grid: header | scrollable content | buttons -->
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="HeaderTextBlock" FontSize="16" FontWeight="Bold"/>
            <TextBlock x:Name="DetailsTextBlock" Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
            <StackPanel>

                <!-- RF4 Core Fields -->
                <Border BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: scalar fields -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ROOF TILE PROPERTIES" FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="0,0,0,8"/>

                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="X (0-127):"/>
                                <TextBox x:Name="TxtTileX" Style="{StaticResource FieldBox}" Width="50"/>
                                <TextBlock Text="Z (0-127):" Foreground="#AAA" VerticalAlignment="Center" Margin="16,0,8,0"/>
                                <TextBox x:Name="TxtTileZ" Style="{StaticResource FieldBox}" Width="50"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Next:"/>
                                <TextBox x:Name="TxtNext" Style="{StaticResource FieldBox}"/>
                                <TextBlock Style="{StaticResource InfoText}" Text="Linked list pointer (S16)"/>
                            </StackPanel>

                            <!-- Split direction & preview -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                    <CheckBox x:Name="ChkDiagonal" Content="Switch Roof Split Direction"
                                              Foreground="White" Margin="0,0,0,6"
                                              ToolTip="RX bit 7 — selects which diagonal of the tile is the straight edge on sloped roofs"
                                              Checked="ChkDiagonal_Changed" Unchecked="ChkDiagonal_Changed"/>
                                    <CheckBox x:Name="ChkRzBit7" Content="Special Marker"
                                              Foreground="White"
                                              ToolTip="RZ bit 7 — always set in original maps; meaning unknown"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <Border BorderBrush="#555" BorderThickness="1" CornerRadius="3"
                                            Width="44" Height="44" Background="#1A1A1A">
                                        <Canvas Width="44" Height="44">
                                            <Line x:Name="LineSplitA" X1="2" Y1="2" X2="42" Y2="42"
                                                  Stroke="#4AAFFF" StrokeThickness="2"/>
                                            <Line x:Name="LineSplitB" X1="42" Y1="2" X2="2" Y2="42"
                                                  Stroke="#4AAFFF" StrokeThickness="2" Visibility="Collapsed"/>
                                        </Canvas>
                                    </Border>
                                    <TextBlock x:Name="TxtSplitLabel" Text="NW → SE"
                                               Foreground="#888" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right: corner height grid (spatial layout) -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <TextBlock Text="CORNER HEIGHTS" FontWeight="SemiBold" FontSize="10" Foreground="#888" Margin="0,0,0,4"/>
                            <Border BorderBrush="#444" BorderThickness="1" CornerRadius="3" Background="#1A1A1A" Width="190">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- NW = DY1 -->
                                    <Border Grid.Row="0" Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,1" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="NW" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox x:Name="TxtDY1" Background="#2A2A2A" Foreground="White" BorderBrush="#555"
                                                         Width="44" Padding="3,2" HorizontalContentAlignment="Right"
                                                         ToolTip="NW corner absolute height in Quarter Storeys"/>
                                                <TextBlock Text="QS" Foreground="#666" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- NE = DY2 -->
                                    <Border Grid.Row="0" Grid.Column="1" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="NE" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox x:Name="TxtDY2" Background="#2A2A2A" Foreground="White" BorderBrush="#555"
                                                         Width="44" Padding="3,2" HorizontalContentAlignment="Right"
                                                         ToolTip="NE corner absolute height in Quarter Storeys"/>
                                                <TextBlock Text="QS" Foreground="#666" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- SW = DY0 -->
                                    <Border Grid.Row="1" Grid.Column="0" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="SW" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox x:Name="TxtDY0" Background="#2A2A2A" Foreground="White" BorderBrush="#555"
                                                         Width="44" Padding="3,2" HorizontalContentAlignment="Right"
                                                         ToolTip="SW corner absolute height in Quarter Storeys"/>
                                                <TextBlock Text="QS" Foreground="#666" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- SE = Y (base) -->
                                    <Border Grid.Row="1" Grid.Column="1" Padding="8,6">
                                        <StackPanel>
                                            <TextBlock Text="SE  (base)" Foreground="#AAA" FontSize="10" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox x:Name="TxtY" Background="#2A2A2A" Foreground="White" BorderBrush="#666"
                                                         Width="44" Padding="3,2" HorizontalContentAlignment="Right"
                                                         ToolTip="SE corner — base height in Quarter Storeys (1 QS = 64 raw)"/>
                                                <TextBlock Text="QS" Foreground="#666" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Foreground="#444" FontSize="9" Margin="0,4,0,0" Width="190" TextWrapping="Wrap"
                                       Text="All corners shown as absolute QS from ground.&#x0A;SE is the base; NW/SW/NE share the same scale."/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RF4 DrawFlags -->
                <Border BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="RF4 DRAW FLAGS" FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="0,0,0,6"/>
                        <WrapPanel>
                            <CheckBox x:Name="ChkDraw0" Style="{StaticResource FlagCheck}" Content="Shadow1"     Checked="DrawFlagCheck_Changed" Unchecked="DrawFlagCheck_Changed"/>
                            <CheckBox x:Name="ChkDraw1" Style="{StaticResource FlagCheck}" Content="Shadow2"     Checked="DrawFlagCheck_Changed" Unchecked="DrawFlagCheck_Changed"/>
                            <CheckBox x:Name="ChkDraw2" Style="{StaticResource FlagCheck}" Content="Shadow3"     Checked="DrawFlagCheck_Changed" Unchecked="DrawFlagCheck_Changed"/>
                            <CheckBox x:Name="ChkDraw7" Style="{StaticResource FlagCheck}" Content="NoDraw (b7)" Checked="DrawFlagCheck_Changed" Unchecked="DrawFlagCheck_Changed"
                                      ToolTip="Suppresses rendering of this tile face"/>
                            <!-- SlideEdge bits — hidden, kept for binary sync only -->
                            <CheckBox x:Name="ChkDraw3" Visibility="Collapsed" Checked="DrawFlagCheck_Changed" Unchecked="DrawFlagCheck_Changed"/>
                            <CheckBox x:Name="ChkDraw4" Visibility="Collapsed" Checked="DrawFlagCheck_Changed" Unchecked="DrawFlagCheck_Changed"/>
                            <CheckBox x:Name="ChkDraw5" Visibility="Collapsed" Checked="DrawFlagCheck_Changed" Unchecked="DrawFlagCheck_Changed"/>
                            <CheckBox x:Name="ChkDraw6" Visibility="Collapsed" Checked="DrawFlagCheck_Changed" Unchecked="DrawFlagCheck_Changed"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- PAP_HI Cell Flags -->
                <Border BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="PAP_HI FLAGS (at this tile)" FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtPapCoords" Style="{StaticResource InfoText}"/>
                        </StackPanel>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox x:Name="ChkPap0"  Style="{StaticResource FlagCheck}" Content="Shadow1"    Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap1"  Style="{StaticResource FlagCheck}" Content="Shadow2"    Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap2"  Style="{StaticResource FlagCheck}" Content="Shadow3"    Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap3"  Style="{StaticResource FlagCheck}" Content="Reflective" Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap4"  Style="{StaticResource FlagCheck}" Content="Hidden"     Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap5"  Style="{StaticResource FlagCheck}" Content="SinkSquare" Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap6"  Style="{StaticResource FlagCheck}" Content="SinkPoint"  Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap7"  Style="{StaticResource FlagCheck}" Content="NoUpper"    Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <CheckBox x:Name="ChkPap8"  Style="{StaticResource FlagCheck}" Content="NoGo"       Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap9"  Style="{StaticResource FlagCheck}" Content="RoofExists" Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap10" Style="{StaticResource FlagCheck}" Content="Zone1"      Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap11" Style="{StaticResource FlagCheck}" Content="Zone2"      Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap12" Style="{StaticResource FlagCheck}" Content="Zone3"      Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap13" Style="{StaticResource FlagCheck}" Content="Zone4"      Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap14" Style="{StaticResource FlagCheck}" Content="FlatRoof"   Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                                <CheckBox x:Name="ChkPap15" Style="{StaticResource FlagCheck}" Content="Water"      Checked="PapFlagCheck_Changed" Unchecked="PapFlagCheck_Changed"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons — always visible, pinned at bottom -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Apply to Selection" Padding="10,6" Margin="0,0,8,0"
                    Click="BtnApplyToSelection_Click" Background="#4A2D5A" Foreground="White" BorderBrush="#7A4A8A"
                    ToolTip="Drag a rectangle on the map to apply Y and DY values to all tiles in that area"/>
            <Button Content="Apply to All" Padding="10,6" Margin="0,0,8,0"
                    Click="BtnApplyToAll_Click" Background="#2D4A5A" Foreground="White" BorderBrush="#4A7A8A"
                    ToolTip="Apply Y, DY, DrawFlags and PAP flags to ALL RF4 tiles in the parent walkable"/>
            <Button Content="Apply" Width="70" Margin="0,0,8,0" Click="BtnApply_Click"
                    ToolTip="Write changes to this single RF4 tile"/>
            <Button Content="OK" Width="70" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click"
                    ToolTip="Apply changes and close"/>
            <Button Content="Cancel" Width="70" IsCancel="True" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
