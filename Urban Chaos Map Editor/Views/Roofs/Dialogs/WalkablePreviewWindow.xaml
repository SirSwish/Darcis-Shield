<Window x:Class="UrbanChaosMapEditor.Views.Roofs.Dialogs.WalkablePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Walkable Preview"
        Height="580"
        Width="860"
        Background="#222222"
        Foreground="White"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="HeaderTextBlock"
                   Grid.Row="0"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,4" />

        <!-- Details -->
        <TextBlock x:Name="DetailsTextBlock"
                   Grid.Row="1"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Opacity="0.8" />

        <!-- Body -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Properties card -->
            <Border Grid.Column="0"
                    BorderBrush="#444"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#111111"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="Walkable Properties" FontWeight="Bold" Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Opacity="0.7" Text="Building:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtBuilding" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Opacity="0.7" Text="Rect (X/Z):" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtRect" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" x:Name="LblYField" Opacity="0.7" Text="Quarter Storeys:" VerticalAlignment="Center"/>
                        <TextBox  Grid.Row="2" Grid.Column="1" x:Name="TxtY"
                                  Background="#333" Foreground="White" BorderBrush="#555"
                                  Padding="4,2" Margin="0,2" Width="60" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Opacity="0.7" Text="StoreyY:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtStoreyY" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Opacity="0.7" Text="StartFace4:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtStartFace4" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Opacity="0.7" Text="EndFace4:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="TxtEndFace4" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Opacity="0.7" Text="Face4 Count:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="TxtFace4Count" VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Opacity="0.7" Text="Next:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="TxtNext" VerticalAlignment="Center"/>

                        <Button Grid.Row="8" Grid.Column="1" x:Name="BtnApply" Content="Apply"
                                Click="BtnApply_Click"
                                Margin="0,8,0,0" Padding="8,3"
                                Background="#4a7c4a" Foreground="White"
                                HorizontalAlignment="Left"/>
                    </Grid>

                    <TextBlock Margin="0,10,0,0" Opacity="0.6"
                               Text="Double-click a RoofFace4 row to open its preview."/>
                </StackPanel>
            </Border>

            <!-- RoofFace4 list -->
            <Border Grid.Column="2"
                    BorderBrush="#444"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#111111"
                    Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="RoofFace4 Span"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <ListView x:Name="RoofFacesList"
                              MouseDoubleClick="RoofFacesList_OnMouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="#" Width="50" DisplayMemberBinding="{Binding Index1}"/>
                                <GridViewColumn Header="Y (QS)" Width="70" DisplayMemberBinding="{Binding Y}"/>
                                <GridViewColumn Header="Vertex Offsets" Width="160" DisplayMemberBinding="{Binding DY}"/>
                                <GridViewColumn Header="Draw Flags" Width="90" DisplayMemberBinding="{Binding FlagsHex}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.Row="3" x:Name="TxtStatus" Margin="0,8,0,0" Opacity="0.7"/>
    </Grid>
</Window>
