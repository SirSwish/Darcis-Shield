<UserControl x:Class="UrbanChaosMapEditor.Views.Roofs.RoofsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:UrbanChaosMapEditor.ViewModels.Roofs"
             HorizontalAlignment="Stretch"
             Foreground="White">

    <UserControl.DataContext>
        <vm:RoofsTabViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <SolidColorBrush x:Key="ListForegroundBrush" Color="White"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ListForegroundBrush}"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#444"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CompactActionButton" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource CompactActionButton}">
            <Setter Property="Background" Value="#2D5A2D"/>
            <Setter Property="BorderBrush" Value="#4A8A4A"/>
        </Style>

        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource CompactActionButton}">
            <Setter Property="Background" Value="#5A2D2D"/>
            <Setter Property="BorderBrush" Value="#8A4A4A"/>
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CFCFCF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Walkables list -->
            <RowDefinition Height="6"/>
            <!-- Splitter -->
            <RowDefinition Height="*"/>
            <!-- RF4 list -->
            <RowDefinition Height="Auto"/>
            <!-- Action buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Altitude tools -->
        </Grid.RowDefinitions>

        <!-- Header with building filter -->
        <Border Grid.Row="0" Background="#2A2D32" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Building:"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                <TextBox Grid.Column="1"
                         x:Name="TxtBuildingFilter"
                         Width="60"
                         Text="{Binding SelectedBuildingId, UpdateSourceTrigger=PropertyChanged}"
                         Background="#333"
                         Foreground="White"
                         BorderBrush="#555"
                         VerticalContentAlignment="Center"
                         Padding="4,2"
                         ToolTip="Enter building ID to filter walkables (0 = show all)"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Foreground="#AAA"
                           FontSize="11"/>

                <Button Grid.Column="3"
                        Content="Refresh"
                        Padding="8,2"
                        Click="BtnRefresh_Click"
                        ToolTip="Reload walkable and RF4 data"/>
            </Grid>
        </Border>

        <!-- Walkables List -->
        <Border Grid.Row="1"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="4"
                Margin="8,4,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Walkable Regions"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Padding="6,4"
                           Background="#2A2D32"/>

                <ListView Grid.Row="1"
                          x:Name="WalkablesList"
                          ItemsSource="{Binding Walkables}"
                          SelectedItem="{Binding SelectedWalkable, Mode=TwoWay}"
                          SelectionChanged="WalkablesList_OnSelectionChanged"
                          MouseDoubleClick="WalkablesList_OnMouseDoubleClick"
                          Background="Transparent"
                          Foreground="White"
                          BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#" Width="40"
                                            DisplayMemberBinding="{Binding WalkableId1}"/>
                            <GridViewColumn Header="Bld" Width="35"
                                            DisplayMemberBinding="{Binding BuildingId}"/>
                            <GridViewColumn Header="Rect" Width="110"
                                            DisplayMemberBinding="{Binding Rect}"/>
                            <GridViewColumn Header="Y" Width="35"
                                            DisplayMemberBinding="{Binding Y}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Height="6"
                      Margin="8,0"
                      Background="#22000000"
                      ShowsPreview="True"/>

        <!-- RoofFace4 List -->
        <Border Grid.Row="3"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="4"
                Margin="8,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Roof Face 4 Entries"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Padding="6,4"
                           Background="#2A2D32"/>

                <ListView Grid.Row="1"
                          x:Name="RoofFaces4List"
                          ItemsSource="{Binding RoofFaces4}"
                          SelectedItem="{Binding SelectedRoofFace4, Mode=TwoWay}"
                          MouseDoubleClick="RoofFaces4List_OnMouseDoubleClick"
                          Background="Transparent"
                          Foreground="White"
                          BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#" Width="40"
                                            DisplayMemberBinding="{Binding FaceId}"/>
                            <GridViewColumn Header="Y" Width="50"
                                            DisplayMemberBinding="{Binding Y}"/>
                            <GridViewColumn Header="DY" Width="80"
                                            DisplayMemberBinding="{Binding DY}"/>
                            <GridViewColumn Header="Tile" Width="70"
                                            DisplayMemberBinding="{Binding TileDisplay}"/>
                            <GridViewColumn Header="Flags" Width="50"
                                            DisplayMemberBinding="{Binding DrawFlagsHex}"/>
                            <GridViewColumn Header="Next" Width="45"
                                            DisplayMemberBinding="{Binding Next}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Action Buttons -->
        <Border Grid.Row="4"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Margin="8,4,8,0"
                Background="#1A1D20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Walkables row -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Walkables"
                               Style="{StaticResource SectionTitleText}"
                               Width="70"/>

                    <Button Style="{StaticResource GreenButton}"
                            Click="BtnAddWalkable_Click"
                            ToolTip="Add walkable region (draw on map)"
                            Content="Add"/>

                    <Button Style="{StaticResource RedButton}"
                            Margin="0"
                            Click="BtnDeleteWalkable_Click"
                            ToolTip="Delete selected walkable"
                            Content="Remove"/>
                </StackPanel>

                <!-- RoofFace4 row -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Roof Tiles"
                               Style="{StaticResource SectionTitleText}"
                               Width="70"/>

                    <Button Style="{StaticResource GreenButton}"
                            Click="BtnAddRoofFace4_Click"
                            ToolTip="Add RoofFace4 to selected walkable"
                            Content="Add"/>

                    <Button Style="{StaticResource RedButton}"
                            Margin="0"
                            Click="BtnDeleteRoofFace4_Click"
                            ToolTip="Delete selected RoofFace4"
                            Content="Remove"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Cell Altitude Tools -->
        <Border Grid.Row="5"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Margin="8,4,8,8"
                Background="#1A1D20">
            <StackPanel>
                <TextBlock Text="Cell Altitude (Floor Level)" FontWeight="SemiBold" FontSize="11"
                           Foreground="#CFCFCF" Margin="0,0,0,6"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                    <TextBlock Text="Altitude:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="AltitudeInput" Width="64"
                             Text="{Binding AltitudeValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, FallbackValue=0}"
                             Background="#333" Foreground="White" BorderBrush="#555"
                             HorizontalContentAlignment="Right"
                             Padding="4,2"
                             PreviewTextInput="Altitude_PreviewTextInput"
                             ToolTip="World altitude value (stored as value / 8)"/>
                    <TextBlock Text="  (raw:" VerticalAlignment="Center" Margin="8,0,2,0" Foreground="#888"/>
                    <TextBlock x:Name="RawAltitudeDisplay"
                               Text="{Binding AltitudeValueRaw, FallbackValue=0}"
                               VerticalAlignment="Center" Foreground="#888"/>
                    <TextBlock Text=")" VerticalAlignment="Center" Foreground="#888"/>
                </StackPanel>

                <WrapPanel>
                    <Button Margin="0,0,6,0" Padding="8,6"
                            ToolTip="Set Altitude: click cells on the map to set their floor altitude"
                            Click="SetAltitude_Click">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="18" Height="18" Margin="0,0,4,0">
                                <Rectangle Fill="#4488CC" RadiusX="2" RadiusY="2"/>
                                <TextBlock Text="A" FontWeight="Bold" FontSize="10"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Set Alt" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Margin="0,0,6,0" Padding="8,6"
                            ToolTip="Sample Altitude: click a cell on the map to read its altitude"
                            Click="SampleAltitude_Click">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="18" Height="18" Margin="0,0,4,0">
                                <Rectangle Fill="#44CC88" RadiusX="2" RadiusY="2"/>
                                <TextBlock Text="?" FontWeight="Bold" FontSize="10"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Sample" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Margin="0,0,0,0" Padding="8,6"
                            ToolTip="Reset Altitude: click cells on the map to set their altitude back to 0"
                            Click="ResetAltitude_Click">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="18" Height="18" Margin="0,0,4,0">
                                <Rectangle Fill="#CC4444" RadiusX="2" RadiusY="2"/>
                                <TextBlock Text="0" FontWeight="Bold" FontSize="10"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="Reset" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
