<Window x:Class="UrbanChaosMapEditor.Views.Viewport3D.Viewport3DWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="3D Viewport"
        Width="1024" Height="720"
        Background="#101014"
        WindowStartupLocation="CenterOwner"
        Focusable="True"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">
    <Grid>
        <Viewport3D x:Name="Viewport"
                    Focusable="True"
                    MouseDown="Viewport_MouseDown"
                    MouseUp="Viewport_MouseUp"
                    MouseMove="Viewport_MouseMove"
                    MouseWheel="Viewport_MouseWheel">
            <Viewport3D.Camera>
                <PerspectiveCamera x:Name="Camera"
                                   Position="0,0,0"
                                   LookDirection="0,0,1"
                                   UpDirection="0,1,0"
                                   FieldOfView="70"
                                   NearPlaneDistance="4"
                                   FarPlaneDistance="40000"/>
            </Viewport3D.Camera>

            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <Model3DGroup>
                        <AmbientLight x:Name="AmbientSceneLight" Color="#606060"/>
                        <DirectionalLight x:Name="PrimaryDirectionalLight" Color="#C8C8C8" Direction="-0.35,-1,-0.25"/>
                        <DirectionalLight x:Name="SecondaryDirectionalLight" Color="#404040" Direction="0.35,-0.25,1"/>
                    </Model3DGroup>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <ModelVisual3D x:Name="SceneRoot"/>
        </Viewport3D>

        <Rectangle x:Name="AmbientFilterOverlay"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"/>

        <Border HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10"
                Padding="8,4"
                Background="#A0000000"
                CornerRadius="4">
            <StackPanel x:Name="LayerPanel">
                <TextBlock x:Name="HudCoords"
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="12"
                           Text="X: 0   Y: 0   Z: 0"/>
                <TextBlock x:Name="HudOrient"
                           Foreground="#CCCCCC"
                           FontFamily="Consolas"
                           FontSize="11"
                           Text="Yaw: 0°   Pitch: 0°"/>
                <TextBlock Foreground="#888888"
                           FontFamily="Consolas"
                           FontSize="10"
                           Margin="0,4,0,0"
                           Text="WASD / QE move   Shift = sprint   Arrow keys = look   Wheel = speed   Esc = close"/>
                <TextBlock x:Name="HudStatus"
                           Foreground="#8888BB"
                           FontFamily="Consolas"
                           FontSize="10"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="10"
                Padding="10,8"
                Background="#A0000000"
                CornerRadius="4">
            <StackPanel>
                <TextBlock Text="3D Layers"
                           Foreground="White"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <CheckBox x:Name="ChkTextures"
                          Content="Textures"
                          Foreground="White"
                          Margin="0,2,0,2"
                          Checked="LayerToggle_Changed"
                          Unchecked="LayerToggle_Changed"/>

                <CheckBox x:Name="ChkObjects"
                          Content="Objects"
                          Foreground="White"
                          Margin="0,2,0,2"
                          Checked="LayerToggle_Changed"
                          Unchecked="LayerToggle_Changed"/>

                <CheckBox x:Name="ChkBuildings"
                          Content="Buildings"
                          Foreground="White"
                          Margin="0,2,0,2"
                          Checked="LayerToggle_Changed"
                          Unchecked="LayerToggle_Changed"/>

                <CheckBox x:Name="ChkRoofTiles"
                          Content="Roof Tiles"
                          Foreground="White"
                          Margin="0,2,0,2"
                          Checked="LayerToggle_Changed"
                          Unchecked="LayerToggle_Changed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
