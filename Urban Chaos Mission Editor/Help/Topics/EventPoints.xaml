    <Paragraph FontSize="22" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,4">
        Trigger Settings and Listening Modes Reference
    </Paragraph>
    <Paragraph Foreground="#A0A0A0" FontSize="13" Margin="0,0,0,16">
        A reference for Event Point trigger conditions and listening behaviour.
    </Paragraph>

    <BlockUIContainer>
