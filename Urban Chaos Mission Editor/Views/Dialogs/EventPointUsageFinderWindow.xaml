<Window x:Class="UrbanChaosMissionEditor.Views.Dialogs.EventPointUsageFinderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find Event Point Usage"
        Width="720" Height="540"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundDark}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Find Event Point Usage Across UCM Files"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{StaticResource Accent}"
                   Margin="0,0,0,10"/>

        <!-- Directory chooser -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Directory:" Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"
                     x:Name="DirectoryTextBox"
                     Background="{StaticResource BackgroundLight}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderBrush="{StaticResource BorderBrush}"
                     Padding="6,4"
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="2"
                    Content="Browse..."
                    Margin="6,0,0,0"
                    Padding="10,4"
                    Click="Browse_Click"/>
        </Grid>

        <!-- Filter mode -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Search by:" Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      x:Name="FilterModeCombo"
                      Background="{StaticResource Accent}"
                      Foreground="Black"
                      SelectionChanged="FilterModeCombo_SelectionChanged">
                <ComboBoxItem Content="Waypoint Type" IsSelected="True"/>
                <ComboBoxItem Content="Category"/>
            </ComboBox>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Value:" Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center" Margin="10,0,0,0"/>
            <ComboBox Grid.Row="0" Grid.Column="3"
                      x:Name="FilterValueCombo"
                      Background="{StaticResource Accent}"
                      Foreground="Black"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Value"
                      SelectionChanged="FilterValueCombo_SelectionChanged"/>

            <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                        Orientation="Vertical"
                        Margin="10,6,0,0">
                <!-- Optional sub-filter (shown when 'Create Item' is the selected Waypoint Type) -->
                <StackPanel x:Name="ItemFilterPanel"
                            Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Item Type:"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  x:Name="ItemTypeFilterCombo"
                                  Background="{StaticResource Accent}"
                                  Foreground="Black"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  ToolTip="Restrict matches to Create Item event points with this item type"/>
                    </Grid>

                    <CheckBox x:Name="HiddenInPrimOnlyCheckBox"
                              Content="Only items with 'Hidden in prim' flag set"
                              Foreground="{StaticResource TextSecondary}"
                              Margin="0,4,0,0"
                              ToolTip="Restrict matches to Create Item event points where the Hidden In Prim flag (Data[2] bit 1) is set"/>
                </StackPanel>

                <!-- Optional sub-filter (shown when 'Create Vehicle' is the selected Waypoint Type) -->
                <StackPanel x:Name="VehicleFilterPanel"
                            Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Type:"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  x:Name="VehicleTypeFilterCombo"
                                  Background="{StaticResource Accent}"
                                  Foreground="Black"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  ToolTip="Restrict matches to Create Vehicle event points with this vehicle type"/>
                    </Grid>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Behaviour:"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  x:Name="VehicleBehaviorFilterCombo"
                                  Background="{StaticResource Accent}"
                                  Foreground="Black"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  ToolTip="Restrict matches to Create Vehicle event points with this behaviour"/>
                    </Grid>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Key Required:"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  x:Name="VehicleKeyFilterCombo"
                                  Background="{StaticResource Accent}"
                                  Foreground="Black"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  ToolTip="Restrict matches to Create Vehicle event points with this key requirement"/>
                    </Grid>
                </StackPanel>

                <!-- Optional sub-filter (shown when 'Create Camera' is the selected Waypoint Type) -->
                <StackPanel x:Name="CameraFilterPanel"
                            Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Camera Type:"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  x:Name="CameraTypeFilterCombo"
                                  Background="{StaticResource Accent}"
                                  Foreground="Black"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  ToolTip="Restrict matches to Create Camera event points with this camera type"/>
                    </Grid>

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="92"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Movement:"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  x:Name="CameraMovementFilterCombo"
                                  Background="{StaticResource Accent}"
                                  Foreground="Black"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Value"
                                  ToolTip="Restrict matches to Create Camera event points with this movement type"/>
                    </Grid>
                </StackPanel>

                <!-- Optional sub-filter (shown when 'Create Target' is the selected Waypoint Type) -->
                <Grid x:Name="TargetFilterPanel"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Target Type:"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              x:Name="TargetTypeFilterCombo"
                              Background="{StaticResource Accent}"
                              Foreground="Black"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              ToolTip="Restrict matches to Create Target event points with this target type"/>
                </Grid>

                <!-- Optional sub-filter (shown when 'Activate Prim' is the selected Waypoint Type) -->
                <Grid x:Name="ActivatePrimFilterPanel"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Prim Type:"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              x:Name="ActivatePrimTypeFilterCombo"
                              Background="{StaticResource Accent}"
                              Foreground="Black"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              ToolTip="Restrict matches to Activate Prim event points with this prim type"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="SearchButton"
                    Content="Search"
                    Padding="14,5"
                    Background="{StaticResource Accent}"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="Search_Click"/>
            <Button x:Name="CancelSearchButton"
                    Content="Cancel"
                    Padding="14,5"
                    Margin="6,0,0,0"
                    IsEnabled="False"
                    Click="CancelSearch_Click"/>
            <ProgressBar x:Name="ProgressBar"
                         Width="200" Height="14"
                         Margin="14,0,0,0"
                         VerticalAlignment="Center"
                         Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Foreground="{StaticResource TextMuted}"/>
        </StackPanel>

        <!-- Results -->
        <Border Grid.Row="4" Background="{StaticResource BackgroundMedium}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DataGrid x:Name="ResultsGrid"
                      Background="{StaticResource BackgroundMedium}"
                      Foreground="{StaticResource TextPrimary}"
                      RowBackground="{StaticResource BackgroundMedium}"
                      AlternatingRowBackground="{StaticResource BackgroundDark}"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                      VerticalGridLinesBrush="{StaticResource BorderBrush}"
                      BorderThickness="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      MouseDoubleClick="ResultsGrid_MouseDoubleClick">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="220"/>
                    <DataGridTextColumn Header="Matches" Binding="{Binding MatchCount}" Width="80"/>
                    <DataGridTextColumn Header="EP #s" Binding="{Binding EpIndices}" Width="180"/>
                    <DataGridTextColumn Header="Counter #" Binding="{Binding CounterIndex}" Width="90"/>
                    <DataGridTextColumn Header="Increment Number" Binding="{Binding IncrementNumber}" Width="130"/>
                    <DataGridTextColumn Header="Mission" Binding="{Binding MissionName}" Width="160"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding FullPath}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="5"
                   Text="Double-click a row to load that mission in the editor."
                   FontSize="11"
                   Foreground="{StaticResource TextMuted}"
                   Margin="0,6,0,0"/>

        <!-- Footer -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock x:Name="SummaryText"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       Foreground="{StaticResource TextMuted}"/>
            <Button Content="Close"
                    Width="90"
                    IsCancel="True"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
