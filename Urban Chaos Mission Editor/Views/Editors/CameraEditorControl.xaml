<UserControl x:Class="UrbanChaosMissionEditor.Views.Editors.CameraEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="Padding" Value="0,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFEEEEEE"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Text="Camera Settings:" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Camera Type -->
            <Label Grid.Row="0" Grid.Column="0" Content="Camera Type:"/>
            <ComboBox Grid.Row="0" Grid.Column="1"
                      ItemsSource="{Binding CameraTypeOptions}"
                      SelectedIndex="{Binding CameraType}"/>

            <!-- Movement -->
            <Label Grid.Row="1" Grid.Column="0" Content="Movement:"/>
            <ComboBox Grid.Row="1" Grid.Column="1"
                      ItemsSource="{Binding CameraMovementTypeOptions}"
                      SelectedIndex="{Binding CameraMovementType}"/>

            <!-- Speed -->
            <Label Grid.Row="2" Grid.Column="0" Content="Speed:"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding CameraSpeed, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Delay -->
            <Label Grid.Row="3" Grid.Column="0" Content="Delay:"/>
            <TextBox Grid.Row="3" Grid.Column="1"
                     Text="{Binding CameraDelay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Pause Player -->
            <CheckBox Grid.Row="4" Grid.Column="1"
                      Content="Pause Player"
                      IsChecked="{Binding PausePlayer}"
                      Margin="0,8,0,0"/>

            <!-- Direction Lock -->
            <CheckBox Grid.Row="5" Grid.Column="1"
                      Content="Direction Lock"
                      IsChecked="{Binding DirectionLock}"/>

            <!-- Cannot Be Skipped -->
            <CheckBox Grid.Row="6" Grid.Column="1"
                      Content="Cannot Be Skipped"
                      IsChecked="{Binding CannotBeSkipped}"/>
        </Grid>

        <Separator Margin="0,15,0,10" Background="#FF555555"/>

        <!-- Camera Type Descriptions -->
        <TextBlock Text="Camera Types:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBlock TextWrapping="Wrap" Foreground="#FF888888" FontSize="11">
            <Run FontWeight="SemiBold">Normal:</Run> Standard game camera
            <LineBreak/>
            <Run FontWeight="SemiBold">Security Cam:</Run> Fixed position surveillance camera
            <LineBreak/>
            <Run FontWeight="SemiBold">Camcorder:</Run> Handheld camera effect
            <LineBreak/>
            <Run FontWeight="SemiBold">News:</Run> News crew camera style
            <LineBreak/>
            <Run FontWeight="SemiBold">Targetting:</Run> Targeting/aiming camera
        </TextBlock>
    </StackPanel>
</UserControl>
