<Window x:Class="UrbanChaosMissionEditor.Views.EventPointEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Edit EventPoint" 
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FF2D2D30">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="#FFEEEEEE"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="Black"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <!-- Ensure the selected item text is black -->
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="Black"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FF0078D4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF0078D4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="BorderBrush" Value="#FF555555"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="{Binding HeaderText}" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="{Binding SubHeaderText}" FontSize="12" Foreground="#FF888888" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Common Properties -->
                <GroupBox Header="Common Properties">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Index (read-only) -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Index:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Index, Mode=OneWay}" IsReadOnly="True" Margin="0,2"/>

                        <!-- Waypoint Type (read-only for now) -->
                        <Label Grid.Row="1" Grid.Column="0" Content="Type:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding WaypointTypeName, Mode=OneWay}" IsReadOnly="True" Margin="0,2"/>

                        <!-- Group -->
                        <Label Grid.Row="2" Grid.Column="0" Content="Group:"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" 
                                  ItemsSource="{Binding GroupOptions}"
                                  SelectedItem="{Binding SelectedGroup}"
                                  Margin="0,2"/>

                        <!-- Color -->
                        <Label Grid.Row="3" Grid.Column="0" Content="Color:"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" 
                                  ItemsSource="{Binding ColorOptions}"
                                  SelectedIndex="{Binding ColorIndex}"
                                  Margin="0,2"/>
                    </Grid>
                </GroupBox>

                <!-- Position -->
                <GroupBox Header="Position">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- World Coordinates -->
                        <Label Grid.Row="0" Grid.Column="0" Content="World X:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WorldX, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                        <Label Grid.Row="0" Grid.Column="2" Content="Y:"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding WorldY, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                        <Label Grid.Row="0" Grid.Column="4" Content="Z:"/>
                        <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding WorldZ, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

                        <!-- Grid Coordinates (read-only) -->
                        <Label Grid.Row="1" Grid.Column="0" Content="Grid:"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GridPositionText}" VerticalAlignment="Center" Margin="5,2"/>

                        <!-- Select from Map button -->
                        <Button Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="4" 
                                Content="📍 Select Position on Map" 
                                Click="SelectPositionOnMap_Click"
                                Background="#FF3D5A80" Foreground="White" BorderThickness="0" 
                                Padding="8,4" Margin="5,2" HorizontalAlignment="Right"
                                ToolTip="Click to select position by clicking on the map"/>

                        <!-- Direction -->
                        <Label Grid.Row="2" Grid.Column="0" Content="Direction:"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Direction, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="4" 
                                   Text="{Binding DirectionDegreesText}" 
                                   VerticalAlignment="Center" Margin="5,2"/>

                        <!-- Help text -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="6" 
                                   Text="Tip: Drag EventPoints on map to move. Drag arrow tip to rotate. Arrow keys for fine adjustment." 
                                   Foreground="#FF888888" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    </Grid>
                </GroupBox>

                <!-- Type-Specific Properties -->
                <GroupBox Header="Type-Specific Properties">
                    <ContentControl x:Name="TypeSpecificContent" Content="{Binding TypeSpecificEditor}"/>
                </GroupBox>

                <!-- Trigger Settings -->
                <GroupBox Header="Trigger Settings">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Triggered By -->
                            <Label Grid.Row="0" Grid.Column="0" Content="Triggered By:"/>
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding TriggerTypeOptions}"
                                      SelectedItem="{Binding SelectedTriggerType}"
                                      Margin="0,2"/>

                            <!-- Negate / Invert -->
                            <CheckBox Grid.Row="1" Grid.Column="1"
                                      Content="Negate / Invert condition"
                                      IsChecked="{Binding InvertCondition}"
                                      ToolTip="Inverts the trigger condition (WPT_FLAGS_INVERSE bit 0x02)"
                                      Margin="0,5,0,3"/>

                            <!-- On Trigger -->
                            <Label Grid.Row="2" Grid.Column="0" Content="Listening Mode:"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      ItemsSource="{Binding OnTriggerOptions}"
                                      SelectedItem="{Binding SelectedOnTrigger}"
                                      Margin="0,2"/>

                            <!-- After Timer (only visible when OnTrigger == ActiveTime) -->
                            <Label Grid.Row="3" Grid.Column="0" Content="After Timer (ticks):"
                                   Visibility="{Binding AfterTimerVisibility}"/>
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Text="{Binding AfterTimer, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding AfterTimerVisibility}"
                                     ToolTip="How long (in ticks) to stay active before resetting — used by 'Stay active for time then reset'"
                                     Margin="0,2"/>

                            <!-- EP Ref (dynamic label; hidden for None triggers) -->
                            <Label Grid.Row="4" Grid.Column="0"
                                   Content="{Binding EPRefLabel}"
                                   Visibility="{Binding EPRefVisibility}"/>
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Text="{Binding EPRef, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding EPRefVisibility}"
                                     Margin="0,2"/>

                            <!-- EP Ref Bool (dynamic label; only for boolean / person triggers) -->
                            <Label Grid.Row="5" Grid.Column="0"
                                   Content="{Binding EPRefBoolLabel}"
                                   Visibility="{Binding EPRefBoolVisibility}"/>
                            <TextBox Grid.Row="5" Grid.Column="1"
                                     Text="{Binding EPRefBool, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding EPRefBoolVisibility}"
                                     Margin="0,2"/>

                            <!-- Radius (dynamic label; hidden for Depend / EPRefOnly / None) -->
                            <Label Grid.Row="6" Grid.Column="0"
                                   Content="{Binding RadiusLabel}"
                                   Visibility="{Binding RadiusVisibility}"/>
                            <TextBox Grid.Row="6" Grid.Column="1"
                                     Text="{Binding Radius, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding RadiusVisibility}"
                                     Margin="0,2"/>

                            <!-- Radius interpreted hint (e.g. "= 3.50 seconds") -->
                            <TextBlock Grid.Row="7" Grid.Column="1"
                                       Text="{Binding RadiusInterpretedText}"
                                       Visibility="{Binding RadiusInterpretedVisibility}"
                                       Foreground="#FF888888" FontSize="10"
                                       Margin="2,0,0,4"/>

                            <!-- Cuboid Half-Size Z (only for Cuboid trigger) -->
                            <Label Grid.Row="8" Grid.Column="0" Content="Cuboid Half-Size Z:"
                                   Visibility="{Binding CuboidZVisibility}"/>
                            <TextBox Grid.Row="8" Grid.Column="1"
                                     Text="{Binding CuboidHalfSizeZ, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding CuboidZVisibility}"
                                     ToolTip="High 16 bits of Radius — half-extent on the Z axis"
                                     Margin="0,2"/>

                            <!-- Optional (PSX) -->
                            <CheckBox Grid.Row="9" Grid.Column="1"
                                      Content="Optional (PSX export only)"
                                      IsChecked="{Binding IsOptional}"
                                      ToolTip="EP may be omitted in PSX version (WPT_FLAGS_OPTIONAL bit 0x20)"
                                      Margin="0,5,0,3"/>

                            <!-- Referenced (read-only) -->
                            <Label Grid.Row="10" Grid.Column="0" Content="Referenced:"
                                   ToolTip="Set automatically on export — do not edit manually"/>
                            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" Margin="0,3">
                                <CheckBox IsChecked="{Binding IsReferenced, Mode=OneWay}"
                                          IsEnabled="False"/>
                                <TextBlock Text="(computed on export)" Foreground="#FF666666"
                                           FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Engine override warning: Person Used → Message while unreferenced -->
                        <Border Visibility="{Binding PersonUsedMessageWarningVisibility}"
                                Background="#FF3D2B00" BorderBrush="#FFAA7700" BorderThickness="1"
                                CornerRadius="2" Padding="8,6" Margin="0,8,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="#FFDDAA44" FontSize="10">
                                <Run FontWeight="SemiBold">Engine override:</Run>
                                Unreferenced 'Person Used → Message' EPs are forced to Stay While by the engine, regardless of the Listening Mode setting.
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="OkButton_Click" IsDefault="True"
                    Background="#FF0078D4" Foreground="White" BorderThickness="0" Padding="10,5"/>
            <Button Content="Cancel" Width="80" Click="CancelButton_Click" IsCancel="True"
                    Background="#FF555555" Foreground="White" BorderThickness="0" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>
