<Window x:Class="UrbanChaosMissionEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrbanChaosMissionEditor.Views"
        xmlns:vm="clr-namespace:UrbanChaosMissionEditor.ViewModels"
        xmlns:conv="clr-namespace:UrbanChaosMissionEditor.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <conv:ColorIndexToBrushConverter x:Key="ColorIndexToBrush"/>
        <conv:CategoryToBrushConverter x:Key="CategoryToBrush"/>
        <conv:FlagsToStringConverter x:Key="FlagsToString"/>
        <conv:IntToHexConverter x:Key="IntToHex"/>
        <conv:EnumToBoolConverter x:Key="EnumToBool"/>
        <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>

        <!-- Toggle button style for layer visibility (GREEN theme) -->
        <Style x:Key="LayerToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="ForestGreen"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#32CD32"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#888"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox (collapsed selection shows black text on green background) -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="ForestGreen"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ComboBox dropdown items -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="6,4"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>

                <!-- Selected item in the dropdown: black text -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="ForestGreen"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Expander Style for dark theme -->
        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- CheckBox style for dark theme -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>

        <!-- Toolbar button style -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4C4C4C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="ForestGreen"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styles -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Category Pill Style -->
        <Style x:Key="CategoryPillStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ListView Style -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="ForestGreen"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Key="M" Modifiers="Ctrl" Command="{Binding AddEventPointCommand}"/>
        <KeyBinding Key="Add" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Key="Subtract" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ResetZoomCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteEventPointCommand}"/>
        <KeyBinding Key="C" Modifiers="Ctrl" Command="{Binding CopyEventPointCommand}"/>
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding PasteEventPointCommand}"/>
        <KeyBinding Key="D3" Modifiers="Ctrl" Command="{x:Static local:MainWindow.Open3DViewportCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#2D2D2D" Foreground="#FFFFFF">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewFileCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open..." Command="{Binding OpenFileCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save" Command="{Binding SaveFileCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As..." Command="{Binding SaveAsFileCommand}" InputGestureText="Ctrl+Shift+S"/>
                <MenuItem Header="_Close" Command="{Binding CloseFileCommand}" InputGestureText="Ctrl+W"/>
                <Separator/>
                <MenuItem Header="Open _Map..." Command="{Binding OpenMapCommand}" ToolTip="Manually load a .iam map file"/>
                <MenuItem Header="Open _Lights..." Command="{Binding OpenLightsCommand}" ToolTip="Manually load a .lgt lights file"/>
                <MenuItem Header="_Mission Properties..." Command="{Binding MissionPropertiesCommand}" ToolTip="Edit mission file references and settings"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Add EventPoint..." Command="{Binding AddEventPointCommand}" InputGestureText="Ctrl+M" ToolTip="Add a new EventPoint at current mouse position"/>
                <MenuItem Header="_Delete EventPoint" Command="{Binding DeleteEventPointCommand}" InputGestureText="Delete" ToolTip="Delete the selected EventPoint"/>
                <MenuItem Header="_Copy EventPoint" Command="{Binding CopyEventPointCommand}" InputGestureText="Ctrl+C" ToolTip="Copy the selected EventPoint"/>
                <MenuItem Header="_Paste EventPoint" Command="{Binding PasteEventPointCommand}" InputGestureText="Ctrl+V" ToolTip="Paste EventPoint at cursor position"/>
                <Separator/>
                <MenuItem Header="Ce_nter On Selected" Command="{Binding CenterOnSelectedCommand}" ToolTip="Center the map on the selected EventPoint"/>
            </MenuItem>
            <MenuItem Header="_Zones">
                <MenuItem Header="_Paint Zone Mode" IsCheckable="True" IsChecked="{Binding IsZonePaintMode}" ToolTip="Click and drag on map to paint zones"/>
                <MenuItem Header="_Erase Zone Mode" IsCheckable="True" IsChecked="{Binding IsZoneEraseMode}" ToolTip="Click and drag on map to erase zones"/>
                <Separator/>
                <MenuItem Header="Zone _Type">
                    <MenuItem Header="Inside (Black)" IsCheckable="True"
              IsChecked="{Binding SelectedZoneType, Converter={StaticResource EnumToBool}, ConverterParameter=Inside}"/>
                    <MenuItem Header="Reverb (Grey)" IsCheckable="True"
              IsChecked="{Binding SelectedZoneType, Converter={StaticResource EnumToBool}, ConverterParameter=Reverb}"/>
                    <MenuItem Header="No Wander (Red)" IsCheckable="True"
              IsChecked="{Binding SelectedZoneType, Converter={StaticResource EnumToBool}, ConverterParameter=NoWander}"/>

                    <Separator/>

                    <MenuItem Header="Zone 1 (Blue)" IsCheckable="True"
              IsChecked="{Binding SelectedZoneType, Converter={StaticResource EnumToBool}, ConverterParameter=Zone1}"/>
                    <MenuItem Header="Zone 2 (Cyan)" IsCheckable="True"
              IsChecked="{Binding SelectedZoneType, Converter={StaticResource EnumToBool}, ConverterParameter=Zone2}"/>
                    <MenuItem Header="Zone 3 (Yellow)" IsCheckable="True"
              IsChecked="{Binding SelectedZoneType, Converter={StaticResource EnumToBool}, ConverterParameter=Zone3}"/>
                    <MenuItem Header="Zone 4 (Magenta)" IsCheckable="True"
              IsChecked="{Binding SelectedZoneType, Converter={StaticResource EnumToBool}, ConverterParameter=Zone4}"/>

                    <Separator/>

                    <MenuItem Header="No-Go (Dark Grey)" IsCheckable="True"
              IsChecked="{Binding SelectedZoneType, Converter={StaticResource EnumToBool}, ConverterParameter=NoGo}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Clear _All Zones" Command="{Binding ClearAllZonesCommand}" ToolTip="Remove all zone data"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Open _3D Viewport..." Click="Open3DViewport_Click" InputGestureText="Ctrl+3"/>
                <Separator/>
                <MenuItem Header="Zoom _In" Command="{Binding ZoomInCommand}" InputGestureText="+"/>
                <MenuItem Header="Zoom _Out" Command="{Binding ZoomOutCommand}" InputGestureText="-"/>
                <MenuItem Header="_Reset Zoom" Command="{Binding ResetZoomCommand}" InputGestureText="Ctrl+0"/>
                <Separator/>
                <MenuItem Header="Mission Layers">
                    <MenuItem Header="Show _Event Points" IsCheckable="True" IsChecked="{Binding ShowEventPoints}"/>
                    <MenuItem Header="Show _Zones" IsCheckable="True" IsChecked="{Binding ShowZones}"/>
                </MenuItem>
                <MenuItem Header="Map Layers">
                    <MenuItem Header="Show _Grid Lines" IsCheckable="True" IsChecked="{Binding ShowGridLines}"/>
                    <MenuItem Header="Show _Textures" IsCheckable="True" IsChecked="{Binding ShowTextures}"/>
                    <MenuItem Header="Show _Buildings" IsCheckable="True" IsChecked="{Binding ShowBuildings}"/>
                    <MenuItem Header="Show _Objects" IsCheckable="True" IsChecked="{Binding ShowPrimGraphics}"/>
                    <MenuItem Header="Show _Roof Tiles" IsCheckable="True" IsChecked="{Binding ShowRoofTiles}"/>
                    <MenuItem Header="Show _Altitudes" IsCheckable="True" IsChecked="{Binding ShowRoofAltitudes}"/>
                </MenuItem>
                <MenuItem Header="Lights Layers">
                    <MenuItem Header="Show _Lights" IsCheckable="True" IsChecked="{Binding ShowLights}"/>
                    <MenuItem Header="Show Light _Ranges" IsCheckable="True" IsChecked="{Binding ShowLightRanges}"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Show All Categories" Command="{Binding ShowAllCategoriesCommand}"/>
                <MenuItem Header="_Hide All Categories" Command="{Binding HideAllCategoriesCommand}"/>
            </MenuItem>
            <MenuItem Header="_Debug">
                <MenuItem Header="_Find Event Point Usage..." Click="FindEventPointUsage_Click"
                          ToolTip="Scan a directory of UCM files to find missions using a specific event point type"/>
                <MenuItem Header="Find _Trigger Usage..." Click="FindTriggerUsage_Click"
                          ToolTip="Scan a directory of UCM files to find missions using a specific trigger type"/>
                <Separator/>
                <MenuItem Header="Export _All Event Points to JSON..." Click="ExportAllEventPoints_Click"
                          ToolTip="Scan a workspace folder and export every UCM Event Point, including trigger and type-specific data, to one JSON file"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Mission Editor Help" Click="Help_Click"/>
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#2D2D2D" Padding="4">
            <WrapPanel>
                <!-- File operations -->
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="📁 Open" 
                Command="{Binding OpenFileCommand}" ToolTip="Open UCM File (Ctrl+O)"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="🗺️ Map"
                Command="{Binding OpenMapCommand}" ToolTip="Open Map File"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="✏️ Edit Map"
                Command="{Binding EditMapCommand}" ToolTip="Open loaded map in Map Editor"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="💡 Lights"
                Command="{Binding OpenLightsCommand}" ToolTip="Open Lights File"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="✏️ Edit Lights"
                Command="{Binding EditLightsCommand}" ToolTip="Open loaded lights in Light Editor"/>
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="3D"
                Click="Open3DViewport_Click" ToolTip="Open 3D viewport (Ctrl+3)"
                IsEnabled="{Binding IsMapLoaded}"/>

                <Separator Margin="8,0" Background="#555"/>

                <!-- Layer visibility toggles - ORGANIZED BY: Mission | Map | Lights -->
                <TextBlock Text="Layers:" Foreground="#AAA" VerticalAlignment="Center" Margin="4,0"/>

                <!-- Mission layers -->
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Events" 
                      IsChecked="{Binding ShowEventPoints}" IsEnabled="{Binding HasMission}"
                      ToolTip="Show/hide EventPoints"/>
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Zones" 
                      IsChecked="{Binding ShowZones}" IsEnabled="{Binding HasMission}"
                      ToolTip="Show/hide Mission Zones"/>

                <Separator Margin="4,4" Background="#444" Width="1"/>

                <!-- Map layers -->
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Grid" 
                      IsChecked="{Binding ShowGridLines}"
                      ToolTip="Show/hide grid lines"/>
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Textures" 
                      IsChecked="{Binding ShowTextures}" IsEnabled="{Binding IsMapLoaded}"
                      ToolTip="Show/hide terrain textures"/>
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Buildings" 
                      IsChecked="{Binding ShowBuildings}" IsEnabled="{Binding IsMapLoaded}"
                      ToolTip="Show/hide buildings"/>
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Objects" 
                      IsChecked="{Binding ShowPrimGraphics}" IsEnabled="{Binding IsMapLoaded}"
                      ToolTip="Show/hide prim objects"/>
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Roofs" 
                      IsChecked="{Binding ShowRoofTiles}" IsEnabled="{Binding IsMapLoaded}"
                      ToolTip="Show/hide RF4 roof tiles"/>
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Alts" 
                      IsChecked="{Binding ShowRoofAltitudes}" IsEnabled="{Binding IsMapLoaded}"
                      ToolTip="Show/hide PAP altitude labels"/>

                <Separator Margin="4,4" Background="#444" Width="1"/>

                <!-- Lights layers -->
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Lights" 
                      IsChecked="{Binding ShowLights}" IsEnabled="{Binding IsLightsLoaded}"
                      ToolTip="Show/hide light positions"/>
                <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="Ranges" 
                      IsChecked="{Binding ShowLightRanges}" IsEnabled="{Binding IsLightsLoaded}"
                      ToolTip="Show/hide light range circles"/>

                <Separator Margin="8,0" Background="#555"/>

                <!-- Zone painting tools (only visible when mission loaded) -->
                <StackPanel Orientation="Horizontal" 
                    Visibility="{Binding HasMission, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Zone:" Foreground="#AAA" VerticalAlignment="Center" Margin="4,0"/>
                    <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="🖌️ Paint" 
                          IsChecked="{Binding IsZonePaintMode}"
                          ToolTip="Paint zones on map"/>
                    <ToggleButton Style="{StaticResource LayerToggleStyle}" Content="🧹 Erase" 
                          IsChecked="{Binding IsZoneEraseMode}"
                          ToolTip="Erase zones from map"/>
                    <ComboBox ItemsSource="{Binding ZoneTypeOptions}"
                      SelectedValue="{Binding SelectedZoneType}"
                      SelectedValuePath="Value"
                      DisplayMemberPath="DisplayName"
                      Width="100" Margin="4,0"
                      ToolTip="Zone type to paint"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Main Content -->
        <Grid x:Name="MainContentGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="280" MinWidth="200"/>
                <ColumnDefinition x:Name="LeftSplitterColumn" Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightSplitterColumn" Width="Auto"/>
                <ColumnDefinition x:Name="RightPanelColumn" Width="420" MinWidth="340"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Mission Info + EventPoint List -->
            <Grid x:Name="LeftSidePanel" Grid.Column="0" Background="#252526">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Mission Info Panel -->
                <Border Grid.Row="0" Background="#1E1E1E" Padding="10" Margin="5"
        Visibility="{Binding HasMission, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <!-- Header with Edit button -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MISSION INFO" Style="{StaticResource HeaderTextStyle}"/>
                            <Button Grid.Column="1" Content="✏️ Edit" 
                    Command="{Binding MissionPropertiesCommand}"
                    Padding="8,2" FontSize="10"
                    Background="#3C3C3C" Foreground="#AAA" BorderThickness="0"
                    ToolTip="Edit Mission Properties"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Mission name -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Mission:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MissionName}" Style="{StaticResource ValueTextStyle}" 
                       TextTrimming="CharacterEllipsis" ToolTip="{Binding MissionName}"/>

                            <!-- Brief name -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Brief:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BriefName}" Style="{StaticResource ValueTextStyle}" 
                       TextTrimming="CharacterEllipsis" ToolTip="{Binding BriefName}"/>

                            <!-- Map path -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Map:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MapName}" Style="{StaticResource ValueTextStyle}" 
                       TextTrimming="CharacterEllipsis" ToolTip="{Binding MapName}"/>

                            <!-- Light map path -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Light Map:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LightMapName}" Style="{StaticResource ValueTextStyle}" 
                       TextTrimming="CharacterEllipsis" ToolTip="{Binding LightMapName}"/>

                            <!-- Version -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Version:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Version}" Style="{StaticResource ValueTextStyle}"/>

                            <!-- Event point count -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Event Pts:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding EventPointCount}" Style="{StaticResource ValueTextStyle}"/>

                            <!-- Separator -->
                            <Separator Grid.Row="6" Grid.ColumnSpan="2" Background="#333" Margin="0,4"/>

                            <!-- Rates section -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Crime:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding CrimeRate}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Civilians:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding CivsRate}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Boredom:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding BoredomRate}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Cars:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding CarsRate}" Style="{StaticResource ValueTextStyle}"/>

                            <TextBlock Grid.Row="11" Grid.Column="0" Text="Music:" Style="{StaticResource LabelTextStyle}"/>
                            <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding MusicWorld}" Style="{StaticResource ValueTextStyle}"/>

                            <!-- Separator -->
                            <Separator Grid.Row="12" Grid.ColumnSpan="2" Background="#333" Margin="0,4,0,0"/>
                        </Grid>

                        <!-- Loaded files info (collapsible) -->
                        <Expander Header="Loaded Files" IsExpanded="False" Foreground="#888" FontSize="10" Margin="0,4,0,0">
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Map File:" Style="{StaticResource LabelTextStyle}" Foreground="#666"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LoadedMapFileName}" Style="{StaticResource ValueTextStyle}" 
                           Foreground="{Binding IsMapLoaded, Converter={StaticResource BoolToColorConverter}}"
                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Lights File:" Style="{StaticResource LabelTextStyle}" Foreground="#666"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LoadedLightsFileName}" Style="{StaticResource ValueTextStyle}"
                           Foreground="{Binding IsLightsLoaded, Converter={StaticResource BoolToColorConverter}}"
                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- Filters Section -->
                <Border Grid.Row="1" Background="#1E1E1E" Padding="8" Margin="5"
        Visibility="{Binding HasMission, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <!-- Header with Clear button -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FILTERS" Style="{StaticResource HeaderTextStyle}"/>
                            <Button Grid.Column="1" Content="Clear" 
                    Command="{Binding ClearFiltersCommand}"
                    Padding="8,2" FontSize="10"
                    Background="#3C3C3C" Foreground="#AAA" BorderThickness="0"/>
                        </Grid>

                        <!-- Text Search -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1" 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Background="#2D2D2D" Foreground="#FFF" BorderBrush="#444"
                     Padding="6,4" FontSize="11"
                     ToolTip="Search by name, summary, or index"/>
                        </Grid>

                        <!-- Color and Group Filters Row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Color Filter -->
                            <ComboBox Grid.Column="0"
                          ItemsSource="{Binding ColorFilterOptions}"
                          SelectedValue="{Binding SelectedColorFilter}"
                          SelectedValuePath="Value"
                          FontSize="11"
                          ToolTip="Filter by color">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="10" Height="10"
                                         Fill="{Binding ColorBrush}"
                                         Stroke="#333" StrokeThickness="1"
                                         Margin="0,0,6,0"
                                         Visibility="{Binding ColorBrush, Converter={StaticResource NullToVisibility}}"/>
                                                            <TextBlock Text="{Binding DisplayName}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Group Filter -->
                            <ComboBox Grid.Column="2"
          ItemsSource="{Binding GroupFilterOptions}"
          SelectedValue="{Binding SelectedGroupFilter}"
          SelectedValuePath="Value"
          DisplayMemberPath="DisplayName"
          FontSize="11"
          ToolTip="Filter by group letter"/>
                        </Grid>

                        <!-- Map View Filter -->
                        <CheckBox Content="Only show EventPoints in Map View"
                                  IsChecked="{Binding FilterByMapView}"
                                  Foreground="#CCC" FontSize="11"
                                  Margin="0,0,0,8"
                                  ToolTip="Only show EventPoints currently visible in the 2D map viewport. Updates as you scroll or zoom."/>

                        <!-- Category Filter (Compact Checkboxes) -->
                        <Expander Header="Categories" IsExpanded="False" 
                  Foreground="#AAA" FontSize="11">
                            <ItemsControl ItemsSource="{Binding CategoryFilters}" Margin="0,4,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                  Margin="0,2,8,2"
                                  Foreground="#CCC" FontSize="10"
                                  ToolTip="{Binding Count, StringFormat={}{0} items}">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" 
                                         Fill="{Binding DisplayBrush}" 
                                         Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Name}"/>
                                                <TextBlock Text="{Binding Count, StringFormat=' ({0})'}" 
                                           Foreground="#666" FontSize="9"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- EventPoint List -->
                <Border Grid.Row="2" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Add/Delete buttons -->
                        <Grid Grid.Row="0" Background="#1E1E1E" Margin="5,5,5,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="EVENT POINTS" Style="{StaticResource HeaderTextStyle}" Padding="5"/>
                            <Button Grid.Column="1" Content="+ Add" 
                                    Command="{Binding AddEventPointCommand}"
                                    ToolTip="Add new EventPoint (Ctrl+M)"
                                    Padding="8,2" Margin="5,0"
                                    Background="#0078D4" Foreground="White" BorderThickness="0"/>
                            <Button Grid.Column="2" Content="Delete" 
                                    Command="{Binding DeleteEventPointCommand}"
                                    ToolTip="Delete selected EventPoint"
                                    Padding="8,2" Margin="0,0,5,0"
                                    Background="#D41C1C" Foreground="White" BorderThickness="0"/>
                        </Grid>

                        <ListView Grid.Row="1"
          x:Name="EventPointsListView"
          ItemsSource="{Binding EventPointsView}"
          SelectedItem="{Binding SelectedEventPoint}"
          SelectionMode="Single"
          VirtualizingPanel.IsVirtualizing="True"
          VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="4"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="ForestGreen"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D3D3D"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Color indicator -->
                                        <Ellipse Grid.Column="0" Width="12" Height="12"
                         Fill="{Binding ColorIndex, Converter={StaticResource ColorIndexToBrush}}"
                         Stroke="#333333" StrokeThickness="1"/>
                                        <!-- Name and summary -->
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}" 
                               Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SummaryTruncated}" 
                               Foreground="#888888" FontSize="10"
                               TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <!-- Category pill -->
                                        <Border Grid.Column="2" 
                        Background="{Binding CategoryBrush}"
                        CornerRadius="8" Padding="6,2" Margin="4,0,0,0"
                        VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CategoryName}" 
                               Foreground="White" FontSize="9"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>


                        <!-- Empty state -->
                        <TextBlock Grid.Row="1" 
                                   Text="No mission loaded.&#x0a;Use File → Open to load a .ucm file."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#666666"
                                   TextAlignment="Center"
                                   Visibility="{Binding HasMission, Converter={StaticResource BoolToVisibility}, ConverterParameter=Inverse}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Left Splitter -->
            <GridSplitter x:Name="LeftSideSplitter" Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          Background="#3D3D3D"/>

            <!-- Center: Map View -->
            <Border Grid.Column="2" Background="#1A1A1A" Margin="2">
                <Grid>
                    <!-- Loading overlay -->
                    <Border Background="#80000000" 
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                            Panel.ZIndex="100">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Loading..." Foreground="White" FontSize="18" 
                                       HorizontalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True" Width="200" Height="20" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <local:MapViewControl x:Name="MapView" DataContext="{Binding}"/>

                    <Button x:Name="LeftPanelToggleButton"
                            Content="◀"
                            Width="24" Height="72"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0"
                            Padding="0"
                            Background="#CC2D2D2D"
                            Foreground="White"
                            BorderBrush="#555"
                            Panel.ZIndex="110"
                            Click="ToggleLeftPanel_Click"
                            ToolTip="Collapse left panel"/>

                    <Button x:Name="RightPanelToggleButton"
                            Content="▶"
                            Width="24" Height="72"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            Padding="0"
                            Background="#CC2D2D2D"
                            Foreground="White"
                            BorderBrush="#555"
                            Panel.ZIndex="110"
                            Click="ToggleRightPanel_Click"
                            ToolTip="Collapse right panel"/>
                </Grid>
            </Border>

            <!-- Right Splitter -->
            <GridSplitter x:Name="RightSideSplitter" Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          Background="#3D3D3D"/>

            <!-- Right Panel: Quick-Edit for Selected EventPoint -->
            <Border x:Name="RightSidePanel" Grid.Column="4" Background="#252526">
                <Grid>
                    <!-- Quick-edit panel (live binds against MainViewModel.CurrentEditorVm) -->
                    <DockPanel LastChildFill="True"
                               Visibility="{Binding CurrentEditorVm, Converter={StaticResource NullToVisibility}}">

                        <!-- Bottom-docked Revert button -->
                        <Border DockPanel.Dock="Bottom" Background="#1E1E1E" Padding="10,8">
                            <Button Content="↺ Revert to selection-time state"
                                    Command="{Binding RevertEventPointCommand}"
                                    Background="#3C3C3C" Foreground="#DDD" BorderThickness="0"
                                    Padding="10,6" HorizontalAlignment="Stretch"
                                    ToolTip="Discard all edits made to this EventPoint since it was selected"/>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      DataContext="{Binding CurrentEditorVm}">
                            <StackPanel Margin="10">
                                <!-- Header -->
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding HeaderText}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="{Binding SubHeaderText}" FontSize="11" Foreground="#888" Margin="0,3,0,0"/>
                                </StackPanel>

                                <!-- Common Properties -->
                                <GroupBox Header="Common Properties" Foreground="#CCC" BorderBrush="#555" Margin="0,0,0,10">
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Index:" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Index, Mode=OneWay}" Style="{StaticResource ValueTextStyle}" Margin="0,3"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Type:" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WaypointTypeName, Mode=OneWay}" Style="{StaticResource ValueTextStyle}" Margin="0,3"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Group:" Style="{StaticResource LabelTextStyle}"/>
                                        <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding GroupOptions}"
                                                  SelectedItem="{Binding SelectedGroup}"
                                                  Margin="0,2"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Color:" Style="{StaticResource LabelTextStyle}"/>
                                        <ComboBox Grid.Row="3" Grid.Column="1"
                                                  ItemsSource="{Binding ColorOptions}"
                                                  SelectedIndex="{Binding ColorIndex}"
                                                  Margin="0,2"/>
                                    </Grid>
                                </GroupBox>

                                <!-- Position (read-only display; mutate via Select on Map) -->
                                <GroupBox Header="Position" Foreground="#CCC" BorderBrush="#555" Margin="0,0,0,10">
                                    <StackPanel Margin="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="X:" Style="{StaticResource LabelTextStyle}"
                                                       ToolTip="Map pixel X, matching the 8192 x 8192 viewport. One map tile = 64 pixels."/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PixelX, Mode=OneWay}" Style="{StaticResource ValueTextStyle}" Margin="0,3"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Y (height):" Style="{StaticResource LabelTextStyle}"
                                                       ToolTip="Vertical elevation in game units (256 = 1 storey). Type a value or use the ¼-storey nudge buttons."/>
                                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,2">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Row="0" Grid.Column="0"
                                                         Text="{Binding WorldY, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#3E3E42" Foreground="#EEE" BorderBrush="#555" Padding="4,2"
                                                         ToolTip="Height/elevation in game units. 256 game units = 1 storey. Cannot be set from a 2D map click — type a value here or nudge with the buttons."/>
                                                <Button Grid.Row="0" Grid.Column="1"
                                                        Content="+¼"
                                                        Command="{Binding DataContext.BumpYUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Background="#3C3C3C" Foreground="White" BorderThickness="0"
                                                        Padding="6,2" Margin="4,0,0,0" MinWidth="32"
                                                        ToolTip="Raise Y by a quarter storey (+64 game units)"/>
                                                <Button Grid.Row="0" Grid.Column="2"
                                                        Content="−¼"
                                                        Command="{Binding DataContext.BumpYDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Background="#3C3C3C" Foreground="White" BorderThickness="0"
                                                        Padding="6,2" Margin="3,0,0,0" MinWidth="32"
                                                        ToolTip="Lower Y by a quarter storey (−64 game units)"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                           Text="{Binding QuarterStoreyText, Mode=OneWay}"
                                                           Foreground="#B7D7FF" FontSize="10" Margin="0,3,0,0"
                                                           ToolTip="Current height expressed as quarter-storeys. One quarter-storey = 64 game units."/>
                                            </Grid>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Z:" Style="{StaticResource LabelTextStyle}"
                                                       ToolTip="Map pixel Z, matching the 8192 x 8192 viewport. One map tile = 64 pixels."/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PixelZ, Mode=OneWay}" Style="{StaticResource ValueTextStyle}" Margin="0,3"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Grid:" Style="{StaticResource LabelTextStyle}"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GridPositionText, Mode=OneWay}" Style="{StaticResource ValueTextStyle}" Margin="0,3"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Direction:" Style="{StaticResource LabelTextStyle}"/>
                                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,3">
                                                <TextBlock Text="{Binding Direction, Mode=OneWay}" Style="{StaticResource ValueTextStyle}"/>
                                                <TextBlock Text="{Binding DirectionDegreesText, Mode=OneWay}" Style="{StaticResource ValueTextStyle}" Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <Button Content="📍 Select X / Z on Map"
                                                Command="{Binding DataContext.SelectPositionOnMapCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Background="#3D5A80" Foreground="White" BorderThickness="0"
                                                Padding="8,5" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                ToolTip="Click to set X/Z by clicking on the map. Y (height) must be entered above."/>

                                        <TextBlock Text="Tip: Drag the EventPoint on the map to move; drag the arrow tip to rotate; use arrow keys for fine adjustments. Coordinates are shown in native game units."
                                                   Foreground="#888" FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Type-Specific Properties -->
                                <GroupBox Header="Type-Specific Properties" Foreground="#CCC" BorderBrush="#555" Margin="0,0,0,10">
                                    <ContentControl Content="{Binding TypeSpecificEditor}"/>
                                </GroupBox>

                                <!-- Trigger Settings -->
                                <GroupBox Header="Trigger Settings" Foreground="#CCC" BorderBrush="#555" Margin="0,0,0,10">
                                    <StackPanel Margin="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Triggered By:" Style="{StaticResource LabelTextStyle}"/>
                                            <ComboBox Grid.Row="0" Grid.Column="1"
                                                      ItemsSource="{Binding TriggerTypeOptions}"
                                                      SelectedItem="{Binding SelectedTriggerType}"
                                                      Margin="0,2"/>

                                            <CheckBox Grid.Row="1" Grid.Column="1"
                                                      Content="Negate / Invert condition"
                                                      IsChecked="{Binding InvertCondition}"
                                                      ToolTip="Inverts the trigger condition (WPT_FLAGS_INVERSE bit 0x02)"
                                                      Margin="0,5,0,3"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Listening Mode:" Style="{StaticResource LabelTextStyle}"/>
                                            <ComboBox Grid.Row="2" Grid.Column="1"
                                                      ItemsSource="{Binding OnTriggerOptions}"
                                                      SelectedItem="{Binding SelectedOnTrigger}"
                                                      Margin="0,2"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="After Timer (ticks):" Style="{StaticResource LabelTextStyle}"
                                                       Visibility="{Binding AfterTimerVisibility}"/>
                                            <TextBox Grid.Row="3" Grid.Column="1"
                                                     Text="{Binding AfterTimer, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding AfterTimerVisibility}"
                                                     Background="#3E3E42" Foreground="#EEE" BorderBrush="#555" Padding="4,2"
                                                     ToolTip="How long (in ticks) to stay active before resetting — used by 'Stay active for time then reset'"
                                                     Margin="0,2"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0"
                                                       Text="{Binding EPRefLabel}" Style="{StaticResource LabelTextStyle}"
                                                       Visibility="{Binding EPRefVisibility}"/>
                                            <TextBox Grid.Row="4" Grid.Column="1"
                                                     Text="{Binding EPRef, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding EPRefVisibility}"
                                                     Background="#3E3E42" Foreground="#EEE" BorderBrush="#555" Padding="4,2"
                                                     Margin="0,2"/>

                                            <TextBlock Grid.Row="5" Grid.Column="0"
                                                       Text="{Binding EPRefBoolLabel}" Style="{StaticResource LabelTextStyle}"
                                                       Visibility="{Binding EPRefBoolVisibility}"/>
                                            <TextBox Grid.Row="5" Grid.Column="1"
                                                     Text="{Binding EPRefBool, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding EPRefBoolVisibility}"
                                                     Background="#3E3E42" Foreground="#EEE" BorderBrush="#555" Padding="4,2"
                                                     Margin="0,2"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0"
                                                       Text="{Binding RadiusLabel}" Style="{StaticResource LabelTextStyle}"
                                                       Visibility="{Binding RadiusVisibility}"/>
                                            <TextBox Grid.Row="6" Grid.Column="1"
                                                     Text="{Binding Radius, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding RadiusVisibility}"
                                                     Background="#3E3E42" Foreground="#EEE" BorderBrush="#555" Padding="4,2"
                                                     Margin="0,2"/>

                                            <TextBlock Grid.Row="7" Grid.Column="1"
                                                       Text="{Binding RadiusInterpretedText}"
                                                       Visibility="{Binding RadiusInterpretedVisibility}"
                                                       Foreground="#888" FontSize="10"
                                                       Margin="2,0,0,4"/>

                                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Cuboid Half-Size Z:" Style="{StaticResource LabelTextStyle}"
                                                       Visibility="{Binding CuboidZVisibility}"/>
                                            <TextBox Grid.Row="8" Grid.Column="1"
                                                     Text="{Binding CuboidHalfSizeZ, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding CuboidZVisibility}"
                                                     Background="#3E3E42" Foreground="#EEE" BorderBrush="#555" Padding="4,2"
                                                     ToolTip="High 16 bits of Radius — half-extent on the Z axis"
                                                     Margin="0,2"/>

                                            <CheckBox Grid.Row="9" Grid.Column="1"
                                                      Content="Optional (PSX export only)"
                                                      IsChecked="{Binding IsOptional}"
                                                      ToolTip="EP may be omitted in PSX version (WPT_FLAGS_OPTIONAL bit 0x20)"
                                                      Margin="0,5,0,3"/>

                                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Referenced:" Style="{StaticResource LabelTextStyle}"
                                                       ToolTip="Set automatically on export — do not edit manually"/>
                                            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" Margin="0,3">
                                                <CheckBox IsChecked="{Binding IsReferenced, Mode=OneWay}" IsEnabled="False"/>
                                                <TextBlock Text="(computed on export)" Foreground="#666" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Visibility="{Binding PersonUsedMessageWarningVisibility}"
                                                Background="#3D2B00" BorderBrush="#AA7700" BorderThickness="1"
                                                CornerRadius="2" Padding="8,6" Margin="0,8,0,0">
                                            <TextBlock TextWrapping="Wrap" Foreground="#DDAA44" FontSize="10">
                                                <Run FontWeight="SemiBold">Engine override:</Run>
                                                Unreferenced 'Person Used → Message' EPs are forced to Stay While by the engine, regardless of the Listening Mode setting.
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- No selection state -->
                    <TextBlock Text="Select an event point&#x0a;to edit"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#666666"
                               TextAlignment="Center"
                               Visibility="{Binding CurrentEditorVm, Converter={StaticResource NullToVisibility}, ConverterParameter=Inverse}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="ForestGreen" Padding="5,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="White"/>
                <TextBlock Grid.Column="1" Foreground="White" Margin="20,0">
                    <Run Text="Map: "/>
                    <Run Text="{Binding LoadedMapFileName, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Grid.Column="2" Foreground="White" Margin="20,0">
                    <Run Text="Zoom: "/>
                    <Run Text="{Binding MapZoom, StringFormat=P0, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Grid.Column="3" Text="{Binding FileName}" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>
