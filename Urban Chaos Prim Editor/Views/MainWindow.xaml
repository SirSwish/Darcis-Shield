<Window x:Class="UrbanChaosPrimEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UrbanChaosPrimEditor.ViewModels"
        Title="{Binding WindowTitle}"
        Width="1300" Height="820"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Unloaded="Window_Unloaded"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl"       Command="{Binding OpenDirectoryCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MENU BAR                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Prim File…"
                          Command="{Binding OpenFileCommand}"
                          InputGestureText="Ctrl+O"/>
                <MenuItem Header="Open _Directory…"
                          Command="{Binding OpenDirectoryCommand}"
                          InputGestureText="Ctrl+D"/>
                <MenuItem Header="Set _Texture Directory…"
                          Command="{Binding SetTextureDirCommand}"
                          ToolTip="Pick the folder containing prim texture files (Tex###hi.tga)"/>
                <Separator/>
                <MenuItem Header="_Save As PRM…"
                          Command="{Binding SaveAsPrmCommand}"
                          IsEnabled="{Binding IsFileLoaded}"/>
                <MenuItem Header="Export As _OBJ…"
                          Command="{Binding SaveAsObjCommand}"
                          IsEnabled="{Binding IsFileLoaded}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="File _List Panel"
                          IsCheckable="True"
                          IsChecked="{Binding IsFileListPanelOpen}"/>
                <MenuItem Header="Prim _Information Panel"
                          IsCheckable="True"
                          IsChecked="{Binding IsPrimInfoPanelOpen}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About…" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- TOOLBAR                                                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BackgroundLight}" Padding="6,4"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <WrapPanel>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Open File"
                        Command="{Binding OpenFileCommand}"
                        ToolTip="Open a .prm file (Ctrl+O)"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Open Directory"
                        Command="{Binding OpenDirectoryCommand}"
                        ToolTip="Set the PRM directory (Ctrl+D)"/>

                <Separator Margin="8,2" Background="{StaticResource BorderLightBrush}"/>

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Save As PRM"
                        Command="{Binding SaveAsPrmCommand}"
                        ToolTip="Save as .prm"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Export OBJ"
                        Command="{Binding SaveAsObjCommand}"
                        ToolTip="Export as Wavefront .obj"/>

                <Separator Margin="8,2" Background="{StaticResource BorderLightBrush}"/>

                <!-- Loaded file indicator -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Loaded:" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding LoadedFileName}"
                               Foreground="{StaticResource AccentLight}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR (Yellow)                                            -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource Accent}" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
            </StatusBarItem>
            <Separator Background="#8F7200"/>
            <StatusBarItem>
                <TextBlock Text="{Binding LoadedFileName, StringFormat='File: {0}'}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <!-- Left panel -->
                <ColumnDefinition x:Name="LeftPanelColumn"  Width="240" MinWidth="0"/>
                <!-- Left toggle strip -->
                <ColumnDefinition Width="20"/>
                <!-- Centre viewport -->
                <ColumnDefinition Width="*" MinWidth="200"/>
                <!-- Right toggle strip -->
                <ColumnDefinition Width="20"/>
                <!-- Right panel -->
                <ColumnDefinition x:Name="RightPanelColumn" Width="260" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL — File List ─────────────────────────────── -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                    Background="{StaticResource BackgroundMedium}"
                    Visibility="{Binding IsFileListPanelOpen, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- Panel header -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderStyle}">
                        <DockPanel>
                            <TextBlock Text="PRM Files" Style="{StaticResource HeaderTextStyle}"
                                       VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding DirectoryLabel}"
                                       Style="{StaticResource MutedTextStyle}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="130"
                                       ToolTip="{Binding DirectoryLabel}"/>
                        </DockPanel>
                    </Border>

                    <!-- Set directory button -->
                    <Button DockPanel.Dock="Top"
                            Content="Set Directory…"
                            Command="{Binding OpenDirectoryCommand}"
                            Margin="6,6,6,2"/>

                    <!-- File count -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding PrmFiles.Count, StringFormat='{}{0} file(s)'}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="8,2,8,4"/>

                    <!-- File list -->
                    <ListBox ItemsSource="{Binding PrmFiles}"
                             SelectedItem="{Binding SelectedPrmFile}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <TextBlock Text="{Binding FileName}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FilePath}"/>
                                    <TextBlock Text="{Binding FileSizeDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ── LEFT TOGGLE STRIP ─────────────────────────────────── -->
            <Button Grid.Column="1"
                    Style="{StaticResource PanelToggleStyle}"
                    Click="ToggleLeftPanel_Click"
                    ToolTip="Toggle file list panel">
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#x276E;"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFileListPanelOpen}" Value="False">
                                    <Setter Property="Text" Value="&#x276F;"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

            <!-- ── CENTRE — 3D Viewport ─────────────────────────────── -->
            <Border Grid.Column="2"
                    Background="#121212"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Viewport3D x:Name="Viewport"
                                ClipToBounds="True"
                                Focusable="True"
                                MouseDown="Viewport_MouseDown"
                                MouseWheel="Viewport_MouseWheel">
                        <Viewport3D.Camera>
                            <PerspectiveCamera x:Name="Camera"
                                               Position="0,0,-400"
                                               LookDirection="0,0,1"
                                               UpDirection="0,1,0"
                                               FieldOfView="70"
                                               NearPlaneDistance="1"
                                               FarPlaneDistance="100000"/>
                        </Viewport3D.Camera>

                        <!-- Lighting -->
                        <ModelVisual3D>
                            <ModelVisual3D.Content>
                                <Model3DGroup>
                                    <AmbientLight Color="#606060"/>
                                    <DirectionalLight Color="#FFFFFF" Direction="-0.4,-0.7,-0.8"/>
                                    <DirectionalLight Color="#404040" Direction="0.6,0.4,0.7"/>
                                </Model3DGroup>
                            </ModelVisual3D.Content>
                        </ModelVisual3D>

                        <!-- Scene supplied by ThreeDViewModel -->
                        <ModelVisual3D x:Name="SceneVisual" Content="{Binding ThreeD.Scene}"/>
                    </Viewport3D>

                    <!-- Hint shown until a model is loaded -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFileLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="3D Viewport"
                                   FontSize="22" FontWeight="Light"
                                   Foreground="#333"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Open a .prm file to begin"
                                   FontSize="13"
                                   Foreground="#2A2A2A"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- HUD overlay (top-left) — shown once a model is loaded -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="10" Padding="8,5"
                            Background="#A0000000" CornerRadius="4"
                            IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFileLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock x:Name="HudCoords"
                                       Foreground="White" FontFamily="Consolas" FontSize="12"
                                       Text="X: 0   Y: 0   Z: 0"/>
                            <TextBlock x:Name="HudOrient"
                                       Foreground="#CCCCCC" FontFamily="Consolas" FontSize="11"
                                       Text="Yaw: 0°   Pitch: 0°   Speed: 200"/>
                            <TextBlock x:Name="HudModelRot"
                                       Foreground="#AAAACC" FontFamily="Consolas" FontSize="11"
                                       Text="Model Yaw: 0°   Pitch: 0°"/>
                            <TextBlock Foreground="#888888" FontFamily="Consolas" FontSize="10"
                                       Margin="0,4,0,0"
                                       Text="WASD/QE move · Arrows look · [ ] model yaw · ; ' model pitch · R reset · Wheel = speed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── RIGHT TOGGLE STRIP ────────────────────────────────── -->
            <Button Grid.Column="3"
                    Style="{StaticResource PanelToggleStyle}"
                    Click="ToggleRightPanel_Click"
                    ToolTip="Toggle prim information panel">
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#x276F;"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPrimInfoPanelOpen}" Value="False">
                                    <Setter Property="Text" Value="&#x276E;"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

            <!-- ── RIGHT PANEL — Prim Information ───────────────────── -->
            <Border Grid.Column="4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                    Background="{StaticResource BackgroundMedium}"
                    Visibility="{Binding IsPrimInfoPanelOpen, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- Panel header -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderStyle}">
                        <TextBlock Text="Prim Information" Style="{StaticResource HeaderTextStyle}"/>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">

                            <!-- File section -->
                            <GroupBox Header="File" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding LoadedFile.FileName, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LoadedFile.FilePath}"
                                               Margin="0,2"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Path:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding LoadedFile.FilePath, FallbackValue='—'}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LoadedFile.FilePath}"
                                               Margin="0,2"/>
                                </Grid>
                            </GroupBox>

                            <!-- Geometry section -->
                            <GroupBox Header="Geometry" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Vertices:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding LoadedFile.VertexCount, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}" Margin="0,2"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Faces:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding LoadedFile.FaceCount, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}" Margin="0,2"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Materials:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding LoadedFile.MaterialCount, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}" Margin="0,2"/>
                                </Grid>
                            </GroupBox>

                            <!-- Collision Type -->
                            <GroupBox Header="Collision" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Type:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PrimInfo.CollisionTypeDisplay, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}" Margin="0,2"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </GroupBox>

                            <!-- Damage Types -->
                            <GroupBox Header="Damage Types" Margin="0,0,0,8">
                                <StackPanel Margin="4,4,4,2">
                                    <StackPanel.Resources>
                                        <Style x:Key="FlagDot" TargetType="TextBlock">
                                            <Setter Property="Text" Value="●"/>
                                            <Setter Property="FontSize" Value="8"/>
                                            <Setter Property="Foreground" Value="#444444"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="0,0,5,0"/>
                                        </Style>
                                        <Style x:Key="FlagLabel" TargetType="TextBlock"
                                               BasedOn="{StaticResource MutedTextStyle}">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </StackPanel.Resources>

                                    <!-- Is Damageable -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.IsDamageable}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Is Damageable" Style="{StaticResource FlagLabel}"/>
                                    </StackPanel>

                                    <!-- Explodes -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.Explodes}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Explodes" Style="{StaticResource FlagLabel}"/>
                                    </StackPanel>

                                    <!-- Crumples -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.Crumples}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Crumples" Style="{StaticResource FlagLabel}"/>
                                    </StackPanel>

                                    <!-- No Line of Sight -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.NoLineOfSight}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="No Line of Sight" Style="{StaticResource FlagLabel}"/>
                                    </StackPanel>

                                    <!-- Raw byte hint -->
                                    <TextBlock Margin="0,4,0,0" FontFamily="Consolas" FontSize="10"
                                               Foreground="#555555"
                                               Text="{Binding PrimInfo.RawDamageFlags, StringFormat='raw: 0x{0:X2}'}"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Shadow Type -->
                            <GroupBox Header="Shadow" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Type:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PrimInfo.ShadowTypeDisplay, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}" Margin="0,2"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </GroupBox>

                            <!-- Various Properties -->
                            <GroupBox Header="Properties" Margin="0,0,0,8">
                                <StackPanel Margin="4,4,4,2">
                                    <StackPanel.Resources>
                                        <Style x:Key="FlagDot2" TargetType="TextBlock">
                                            <Setter Property="Text" Value="●"/>
                                            <Setter Property="FontSize" Value="8"/>
                                            <Setter Property="Foreground" Value="#444444"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="0,0,5,0"/>
                                        </Style>
                                        <Style x:Key="FlagLabel2" TargetType="TextBlock"
                                               BasedOn="{StaticResource MutedTextStyle}">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </StackPanel.Resources>

                                    <!-- Is Light -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot2}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.IsLight}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Is Light" Style="{StaticResource FlagLabel2}"/>
                                    </StackPanel>

                                    <!-- Contains Walkable Faces -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot2}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.ContainsWalkableFaces}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Contains Walkable Faces" Style="{StaticResource FlagLabel2}"/>
                                    </StackPanel>

                                    <!-- Has Glare -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot2}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.HasGlare}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Has Glare" Style="{StaticResource FlagLabel2}"/>
                                    </StackPanel>

                                    <!-- Is Rotating Item -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot2}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.IsRotatingItem}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Is Rotating Item" Style="{StaticResource FlagLabel2}"/>
                                    </StackPanel>

                                    <!-- Is Tree -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot2}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.IsTree}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Is Tree" Style="{StaticResource FlagLabel2}"/>
                                    </StackPanel>

                                    <!-- Env Mapped -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot2}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.EnvMapped}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Env Mapped" Style="{StaticResource FlagLabel2}"/>
                                    </StackPanel>

                                    <!-- Just Floor -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot2}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.JustFloor}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="Just Floor" Style="{StaticResource FlagLabel2}"/>
                                    </StackPanel>

                                    <!-- On Floor -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FlagDot2}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimInfo.OnFloor}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="On Floor" Style="{StaticResource FlagLabel2}"/>
                                    </StackPanel>

                                    <!-- Raw byte hint -->
                                    <TextBlock Margin="0,4,0,0" FontFamily="Consolas" FontSize="10"
                                               Foreground="#555555"
                                               Text="{Binding PrimInfo.RawVariousProperties, StringFormat='raw: 0x{0:X2}'}"/>
                                </StackPanel>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
