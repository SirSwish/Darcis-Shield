<Window x:Class="UrbanChaosPrimEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UrbanChaosPrimEditor.ViewModels"
        Title="{Binding WindowTitle}"
        Width="1300" Height="820"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Unloaded="Window_Unloaded"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl"       Command="{Binding OpenDirectoryCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{Binding SaveCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MENU BAR                                                       -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New File"
                          Command="{Binding NewFileCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open Prim File…"
                          Command="{Binding OpenFileCommand}"
                          InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Import OBJ…"
                          Command="{Binding ImportObjCommand}"/>
                <MenuItem Header="Open _Directory…"
                          Command="{Binding OpenDirectoryCommand}"
                          InputGestureText="Ctrl+D"/>
                <MenuItem Header="Set _Texture Directory…"
                          Command="{Binding SetTextureDirCommand}"
                          ToolTip="Pick the folder containing prim texture files (Tex###hi.tga)"/>
                <MenuItem Header="I_mport Texture…"
                          Command="{Binding ImportTextureCommand}"
                          ToolTip="Import an image as the next available Tex###hi.tga in the texture directory"/>
                <Separator/>
                <MenuItem Header="_Save"
                          Command="{Binding SaveCommand}"
                          InputGestureText="Ctrl+S"
                          IsEnabled="{Binding IsFileLoaded}"/>
                <MenuItem Header="_Save As PRM…"
                          Command="{Binding SaveAsPrmCommand}"
                          InputGestureText="Ctrl+Shift+S"
                          IsEnabled="{Binding IsFileLoaded}"/>
                <MenuItem Header="Export As _OBJ…"
                          Command="{Binding SaveAsObjCommand}"
                          IsEnabled="{Binding IsFileLoaded}"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="File _List Panel"
                          IsCheckable="True"
                          IsChecked="{Binding IsFileListPanelOpen}"/>
                <MenuItem Header="Prim _Information Panel"
                          IsCheckable="True"
                          IsChecked="{Binding IsPrimInfoPanelOpen}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Prim Editor Help" Click="Help_Click"/>
                <MenuItem Header="_About…" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- TOOLBAR                                                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BackgroundLight}" Padding="6,4"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <WrapPanel>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="New"
                        Command="{Binding NewFileCommand}"
                        ToolTip="Create a new .prm file (Ctrl+N)"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Open File"
                        Command="{Binding OpenFileCommand}"
                        ToolTip="Open a .prm file (Ctrl+O)"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Import OBJ"
                        Command="{Binding ImportObjCommand}"
                        ToolTip="Import Wavefront .obj geometry"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Open Directory"
                        Command="{Binding OpenDirectoryCommand}"
                        ToolTip="Set the PRM directory (Ctrl+D)"/>

                <Separator Margin="8,2" Background="{StaticResource BorderLightBrush}"/>

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Save"
                        Command="{Binding SaveCommand}"
                        ToolTip="Save .prm (Ctrl+S)"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Save As PRM"
                        Command="{Binding SaveAsPrmCommand}"
                        ToolTip="Save as .prm"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Export OBJ"
                        Command="{Binding SaveAsObjCommand}"
                        ToolTip="Export as Wavefront .obj"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="Reset View"
                        Click="ResetView_Click"
                        ToolTip="Reset the orbit camera around the model"/>

                <Separator Margin="8,2" Background="{StaticResource BorderLightBrush}"/>

                <!-- Loaded file indicator -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Loaded:" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding LoadedFileName}"
                               Foreground="{StaticResource AccentLight}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- EDIT TOOLBAR                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BackgroundLight}" Padding="6,4"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <WrapPanel>
                <TextBlock Text="Edit:" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>

                <RadioButton GroupName="PrimTool" Margin="2,0" Padding="8,3"
                             Content="Select"
                             IsChecked="{Binding IsToolSelect, Mode=OneWay}"
                             Command="{Binding SetToolSelectCommand}"
                             ToolTip="Click a vertex to select it"/>
                <RadioButton GroupName="PrimTool" Margin="2,0" Padding="8,3"
                             Content="Move Point"
                             IsChecked="{Binding IsToolMove, Mode=OneWay}"
                             Command="{Binding SetToolMoveCommand}"
                             ToolTip="Click and drag a vertex on the camera-facing plane"/>
                <RadioButton GroupName="PrimTool" Margin="2,0" Padding="8,3"
                             Content="Add Point"
                             IsChecked="{Binding IsToolAddPoint, Mode=OneWay}"
                             Command="{Binding SetToolAddPointCommand}"
                             ToolTip="Click in the viewport to add a new point"/>
                <RadioButton GroupName="PrimTool" Margin="2,0" Padding="8,3"
                             Content="New Triangle"
                             IsChecked="{Binding IsToolNewTriangle, Mode=OneWay}"
                             Command="{Binding SetToolNewTriangleCommand}"
                             ToolTip="Pick three points to create a triangle face"/>
                <RadioButton GroupName="PrimTool" Margin="2,0" Padding="8,3"
                             Content="New Quad"
                             IsChecked="{Binding IsToolNewQuad, Mode=OneWay}"
                             Command="{Binding SetToolNewQuadCommand}"
                             ToolTip="Pick four points to create a quadrangle face"/>
                <RadioButton GroupName="PrimTool" Margin="2,0" Padding="8,3"
                             Content="Delete Point"
                             IsChecked="{Binding IsToolDeletePoint, Mode=OneWay}"
                             Command="{Binding SetToolDeletePointCommand}"
                             ToolTip="Click a vertex to delete it (only allowed if no face uses it)"/>

                <Separator Margin="8,2" Background="{StaticResource BorderLightBrush}"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Selected:" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding SelectedPointDisplay}"
                               Foreground="{StaticResource AccentLight}"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR (Yellow)                                            -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource Accent}" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
            </StatusBarItem>
            <Separator Background="#8F7200"/>
            <StatusBarItem>
                <TextBlock Text="{Binding LoadedFileName, StringFormat='File: {0}'}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                                   -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <!-- Left panel -->
                <ColumnDefinition x:Name="LeftPanelColumn"  Width="240" MinWidth="0"/>
                <!-- Left toggle strip -->
                <ColumnDefinition Width="20"/>
                <!-- Centre viewport -->
                <ColumnDefinition Width="*" MinWidth="200"/>
                <!-- Right toggle strip -->
                <ColumnDefinition Width="20"/>
                <!-- Right panel -->
                <ColumnDefinition x:Name="RightPanelColumn" Width="260" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL — File List / Textures ────────────────── -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                    Background="{StaticResource BackgroundMedium}"
                    Visibility="{Binding IsFileListPanelOpen, Converter={StaticResource BoolToVis}}">
                <TabControl>

                    <!-- ── Tab 1: PRM Files ── -->
                    <TabItem Header="PRM Files">
                        <DockPanel>
                            <!-- Directory label -->
                            <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderStyle}">
                                <TextBlock Text="{Binding DirectoryLabel}"
                                           Style="{StaticResource MutedTextStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding DirectoryLabel}"/>
                            </Border>

                            <!-- Set directory button -->
                            <Button DockPanel.Dock="Top"
                                    Content="Set Directory…"
                                    Command="{Binding OpenDirectoryCommand}"
                                    Margin="6,6,6,2"/>

                            <!-- File count -->
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{Binding PrmFiles.Count, StringFormat='{}{0} file(s)'}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="8,2,8,4"/>

                            <!-- File list -->
                            <ListBox ItemsSource="{Binding PrmFiles}"
                                     SelectedItem="{Binding SelectedPrmFile}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="64"
                                                    Height="48"
                                                    Background="#141414"
                                                    BorderBrush="#444444"
                                                    BorderThickness="1">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FilePath}"/>
                                                <TextBlock Text="{Binding FileSizeDisplay}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextMuted}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ── Tab 2: Textures ── --></TabControl>
            </Border>

            <!-- ── LEFT TOGGLE STRIP ─────────────────────────────────── -->
            <Button Grid.Column="1"
                    Style="{StaticResource PanelToggleStyle}"
                    Click="ToggleLeftPanel_Click"
                    ToolTip="Toggle file list panel">
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#x276E;"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFileListPanelOpen}" Value="False">
                                    <Setter Property="Text" Value="&#x276F;"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

            <!-- ── CENTRE — 3D Viewport ─────────────────────────────── -->
            <Border Grid.Column="2"
                    Background="#121212"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Viewport3D x:Name="Viewport"
                                ClipToBounds="True"
                                Focusable="True"
                                MouseDown="Viewport_MouseDown"
                                MouseMove="Viewport_MouseMove"
                                MouseUp="Viewport_MouseUp"
                                MouseWheel="Viewport_MouseWheel">
                        <Viewport3D.Camera>
                            <PerspectiveCamera x:Name="Camera"
                                               Position="0,0,-400"
                                               LookDirection="0,0,1"
                                               UpDirection="0,1,0"
                                               FieldOfView="70"
                                               NearPlaneDistance="1"
                                               FarPlaneDistance="100000"/>
                        </Viewport3D.Camera>

                        <!-- Lighting -->
                        <ModelVisual3D>
                            <ModelVisual3D.Content>
                                <Model3DGroup>
                                    <AmbientLight Color="#606060"/>
                                    <DirectionalLight Color="#FFFFFF" Direction="-0.4,-0.7,-0.8"/>
                                    <DirectionalLight Color="#404040" Direction="0.6,0.4,0.7"/>
                                </Model3DGroup>
                            </ModelVisual3D.Content>
                        </ModelVisual3D>

                        <!-- Scene supplied by ThreeDViewModel -->
                        <ModelVisual3D x:Name="SceneVisual" Content="{Binding ThreeD.Scene}"/>
                    </Viewport3D>

                    <!-- Hint shown until a model is loaded -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFileLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="3D Viewport"
                                   FontSize="22" FontWeight="Light"
                                   Foreground="#333"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Open a .prm file to begin"
                                   FontSize="13"
                                   Foreground="#2A2A2A"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- HUD overlay (top-left) — shown once a model is loaded -->
                    <Border VerticalAlignment="Bottom"
                            Margin="10"
                            Background="#D0181818"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="4">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="8,6">
                                <Button Width="24"
                                        Padding="0"
                                        Command="{Binding ToggleTexturePaletteCommand}"
                                        ToolTip="Collapse or expand textures">
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#x25BE;"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTexturePaletteOpen}" Value="False">
                                                        <Setter Property="Text" Value="&#x25B8;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                                <TextBlock Text="Textures"
                                           Foreground="{StaticResource AccentLight}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                                <TextBlock Text="{Binding TextureLibrary.Count, StringFormat=' ({0})'}"
                                           Foreground="#BBBBBB"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                                <Button DockPanel.Dock="Right"
                                        Content="Set Texture Dir"
                                        Command="{Binding SetTextureDirCommand}"
                                        MinWidth="104"
                                        Padding="8,2"
                                        ToolTip="Set texture directory"/>
                                <Button DockPanel.Dock="Right"
                                        Content="+"
                                        Command="{Binding ImportTextureCommand}"
                                        Width="28"
                                        Padding="0,2"
                                        Margin="0,0,4,0"
                                        ToolTip="Import an image as the next available Tex###hi.tga"/>
                            </DockPanel>

                            <Grid DockPanel.Dock="Bottom">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTexturePaletteOpen}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <DockPanel Grid.Column="0" Margin="8,0,8,8">
                                    <TextBlock DockPanel.Dock="Top"
                                               FontSize="10"
                                               Foreground="#AAAAAA"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TextureLibrary.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        Set a texture directory to load Tex###hi.tga files.
                                    </TextBlock>

                                    <ListBox ItemsSource="{Binding TextureLibrary}"
                                             SelectedItem="{Binding SelectedTexture}"
                                             Height="172"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"
                                                           ItemWidth="64"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="2"/>
                                                <Setter Property="Margin" Value="1"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Width="58" ToolTip="{Binding FileName}">
                                                    <Border Width="54" Height="54"
                                                            BorderBrush="#555555"
                                                            BorderThickness="1"
                                                            Background="#1A1A1A">
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding TextureId, StringFormat='Tex{0:D3}'}"
                                                               FontSize="9"
                                                               HorizontalAlignment="Center"
                                                               Foreground="#BBBBBB"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>

                                <DockPanel Grid.Column="1" Margin="0,0,8,8">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                                        <TextBlock Text="UV Region"
                                                   Foreground="#BBBBBB"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <Button DockPanel.Dock="Right"
                                                Content="Reset"
                                                Width="22"
                                                Padding="0,2"
                                                FontSize="10"
                                                Click="ResetTextureSelection_Click"
                                                ToolTip="Revert to full texture"/>
                                    </DockPanel>

                                    <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                        <UniformGrid Columns="4" Margin="0,0,0,3">
                                            <StackPanel Margin="0,0,3,0">
                                                <TextBlock Text="X" FontSize="9" Foreground="#AAAAAA"/>
                                                <TextBox Text="{Binding TextureRegionX, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="10" Padding="2"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,3,0">
                                                <TextBlock Text="Y" FontSize="9" Foreground="#AAAAAA"/>
                                                <TextBox Text="{Binding TextureRegionY, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="10" Padding="2"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,3,0">
                                                <TextBlock Text="W" FontSize="9" Foreground="#AAAAAA"/>
                                                <TextBox Text="{Binding TextureRegionWidth, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="10" Padding="2"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="H" FontSize="9" Foreground="#AAAAAA"/>
                                                <TextBox Text="{Binding TextureRegionHeight, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="10" Padding="2"/>
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Text="{Binding TextureSelectionDisplay}"
                                                   FontSize="10"
                                                   Foreground="#AAAAAA"/>
                                    </StackPanel>

                                    <Border Background="#111111"
                                            BorderBrush="#444444"
                                            BorderThickness="1"
                                            Height="120">
                                        <Grid>
                                            <Image x:Name="TexturePreviewImage"
                                                   Source="{Binding SelectedTexture.Thumbnail}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <Canvas x:Name="TextureSelectionCanvas"
                                                    Background="Transparent"
                                                    Cursor="Cross"
                                                    MouseDown="TextureCanvas_MouseDown"
                                                    MouseMove="TextureCanvas_MouseMove"
                                                    MouseUp="TextureCanvas_MouseUp">
                                                <Rectangle x:Name="SelectionRect"
                                                           Stroke="Orange"
                                                           StrokeThickness="1.5"
                                                           StrokeDashArray="5,2"
                                                           Fill="#44FF8C00"
                                                           Visibility="Collapsed"/>
                                            </Canvas>
                                        </Grid>
                                    </Border>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="10" Padding="8,5"
                            Background="#A0000000" CornerRadius="4"
                            IsHitTestVisible="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFileLoaded}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock x:Name="HudCoords"
                                       Foreground="White" FontFamily="Consolas" FontSize="12"
                                       Text="X: 0   Y: 0   Z: 0"/>
                            <TextBlock x:Name="HudOrient"
                                       Foreground="#CCCCCC" FontFamily="Consolas" FontSize="11"
                                       Text="Yaw: 0°   Pitch: 0°   Speed: 200"/>
                            <TextBlock x:Name="HudModelRot"
                                       Foreground="#AAAACC" FontFamily="Consolas" FontSize="11"
                                       Text="Model Yaw: 0°   Pitch: 0°"/>
                            <TextBlock Foreground="#888888" FontFamily="Consolas" FontSize="10"
                                       Margin="0,4,0,0"
                                       Text="WASD/QE move · Right-drag look · [ ] model yaw · ; ' model pitch · R reset · Wheel = speed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── RIGHT TOGGLE STRIP ────────────────────────────────── -->
            <Button Grid.Column="3"
                    Style="{StaticResource PanelToggleStyle}"
                    Click="ToggleRightPanel_Click"
                    ToolTip="Toggle prim information panel">
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="&#x276F;"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPrimInfoPanelOpen}" Value="False">
                                    <Setter Property="Text" Value="&#x276E;"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Button>

            <!-- ── RIGHT PANEL — Prim Information ───────────────────── -->
            <Border Grid.Column="4"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                    Background="{StaticResource BackgroundMedium}"
                    Visibility="{Binding IsPrimInfoPanelOpen, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- Panel header -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeaderStyle}">
                        <TextBlock Text="Prim Information" Style="{StaticResource HeaderTextStyle}"/>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">

                            <!-- File section -->
                            <GroupBox Header="File" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding LoadedFile.FileName, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LoadedFile.FilePath}"
                                               Margin="0,2"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Path:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding LoadedFile.FilePath, FallbackValue='—'}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding LoadedFile.FilePath}"
                                               Margin="0,2"/>
                                </Grid>
                            </GroupBox>

                            <!-- Geometry section -->
                            <GroupBox Header="Geometry" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Vertices:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding LoadedFile.VertexCount, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}" Margin="0,2"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Faces:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding LoadedFile.FaceCount, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}" Margin="0,2"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Materials:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding LoadedFile.MaterialCount, FallbackValue='—'}"
                                               Style="{StaticResource ValueTextStyle}" Margin="0,2"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Face Materials" Margin="0,0,0,8">
                                <StackPanel Margin="4">
                                    <TextBlock Text="Face"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,0,0,3"/>
                                    <ListBox ItemsSource="{Binding Faces}"
                                             SelectedItem="{Binding SelectedFace}"
                                             DisplayMemberPath="DisplayText"
                                             Height="90"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                                    <Button Content="Rotate UV 90°"
                                            Command="{Binding RotateTexture90Command}"
                                            Margin="0,6,0,0"
                                            ToolTip="Rotate the face's texture UV coordinates 90° clockwise"/>
                                    <Button Content="Apply Selected Texture"
                                            Command="{Binding ApplyTextureToFaceCommand}"
                                            Margin="0,4,0,0"/>
                                    <Button Content="Cancel Texture Preview"
                                            Command="{Binding CancelTexturePreviewCommand}"
                                            Margin="0,4,0,0"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Collision Type -->
                            <GroupBox Header="Collision" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Type:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{x:Static vm:PrimInfoViewModel.CollisionTypes}"
                                              SelectedValue="{Binding PrimInfo.CollisionType, Mode=TwoWay}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Value"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                </Grid>
                            </GroupBox>

                            <!-- Damage Types -->
                            <GroupBox Header="Damage Types" Margin="0,0,0,8">
                                <StackPanel Margin="4,4,4,4">
                                    <CheckBox Content="Is Damageable"
                                              IsChecked="{Binding PrimInfo.IsDamageable, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="Explodes"
                                              IsChecked="{Binding PrimInfo.Explodes, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="Crumples"
                                              IsChecked="{Binding PrimInfo.Crumples, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="No Line of Sight"
                                              IsChecked="{Binding PrimInfo.NoLineOfSight, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <TextBlock Margin="0,4,0,0" FontFamily="Consolas" FontSize="10"
                                               Foreground="#555555"
                                               Text="{Binding PrimInfo.RawDamageFlags, StringFormat='raw: 0x{0:X2}'}"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- Shadow Type -->
                            <GroupBox Header="Shadow" Margin="0,0,0,8">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Type:"
                                               Style="{StaticResource MutedTextStyle}" Margin="0,2"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{x:Static vm:PrimInfoViewModel.ShadowTypes}"
                                              SelectedValue="{Binding PrimInfo.ShadowType, Mode=TwoWay}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Value"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                </Grid>
                            </GroupBox>

                            <!-- Various Properties -->
                            <GroupBox Header="Properties" Margin="0,0,0,8">
                                <StackPanel Margin="4,4,4,4">
                                    <CheckBox Content="Is Light"
                                              IsChecked="{Binding PrimInfo.IsLight, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="Contains Walkable Faces"
                                              IsChecked="{Binding PrimInfo.ContainsWalkableFaces, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="Has Glare"
                                              IsChecked="{Binding PrimInfo.HasGlare, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="Is Rotating Item"
                                              IsChecked="{Binding PrimInfo.IsRotatingItem, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="Is Tree"
                                              IsChecked="{Binding PrimInfo.IsTree, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="Env Mapped"
                                              IsChecked="{Binding PrimInfo.EnvMapped, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="Just Floor"
                                              IsChecked="{Binding PrimInfo.JustFloor, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <CheckBox Content="On Floor"
                                              IsChecked="{Binding PrimInfo.OnFloor, Mode=TwoWay}"
                                              IsEnabled="{Binding IsFileLoaded}"
                                              Margin="0,2"/>
                                    <TextBlock Margin="0,4,0,0" FontFamily="Consolas" FontSize="10"
                                               Foreground="#555555"
                                               Text="{Binding PrimInfo.RawVariousProperties, StringFormat='raw: 0x{0:X2}'}"/>
                                </StackPanel>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
