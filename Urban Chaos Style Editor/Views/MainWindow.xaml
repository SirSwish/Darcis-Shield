<Window x:Class="UrbanChaosStyleEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Urban Chaos Style Editor" Width="1300" Height="800"
        Background="#1E1F22"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A3D42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4D52"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>

        <Style x:Key="WorldListItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3D42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D5A80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Menu -->
        <Menu DockPanel.Dock="Top" Background="#2D2D2D" Foreground="White">
            <MenuItem Header="_File">
                <MenuItem Header="_New Texture Set..." Click="NewTextureSet_Click"/>
                <Separator/>
                <MenuItem Header="_Export World..." Click="Export_Click"/>
                <Separator/>
                <MenuItem Header="_Refresh Worlds" Click="Refresh_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Textures">
                <MenuItem Header="_Import Texture..." Click="ImportTexture_Click"/>
                <MenuItem Header="Import _Batch..." Click="ImportBatch_Click"/>
                <MenuItem Header="_Clear Selected Slot" Click="ClearSlot_Click"/>
            </MenuItem>
            <MenuItem Header="_Sky">
                <MenuItem Header="_Import Sky..." Click="ImportSky_Click"/>
                <MenuItem Header="_Clear Sky" Click="ClearSky_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Style Editor Help" Click="Help_Click"/>
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#2A2D32" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ActionBtn}" Content="New Texture Set" Click="NewTextureSet_Click"/>
                <Rectangle Width="1" Fill="#555" Margin="8,2"/>
                <TextBlock Text="World:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Project.WorldNumber}" VerticalAlignment="Center"
                           FontWeight="Bold" FontSize="14" Foreground="#FFD700" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Project.ProjectName}" VerticalAlignment="Center"
                           Foreground="#888" Margin="0,0,0,0"/>
                <Rectangle Width="1" Fill="#555" Margin="8,2"/>
                <Button Style="{StaticResource ActionBtn}" Content="Import Texture" Click="ImportTexture_Click"/>
                <Button Style="{StaticResource ActionBtn}" Content="Import Batch" Click="ImportBatch_Click"/>
                <Button Style="{StaticResource ActionBtn}" Content="Export World" Click="Export_Click"
                        Background="#2D5A2D" BorderBrush="#3D7A3D"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Height="24" Background="{StaticResource Accent}">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                       Margin="8,0" Foreground="White" FontSize="12"/>
        </Border>

        <!-- Main content: sidebar + slots + right panel -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" MinWidth="140" MaxWidth="260"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR: Discovered Worlds -->
            <Border Grid.Column="0" Background="#2A2D32" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#252830" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="Custom Worlds" FontWeight="Bold" FontSize="13" Foreground="#FFD700"/>
                            <TextBlock Text="{Binding DiscoveredWorlds.Count, StringFormat='{}{0} world(s) found'}"
                                       Foreground="#888" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DiscoveredWorlds}"
                             SelectedItem="{Binding SelectedWorld}"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource WorldListItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Summary}" Foreground="#888" FontSize="10"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Width="6" Background="#333"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- CENTER: Texture slots grid -->
            <Border Grid.Column="2" Background="#252526" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontWeight="Bold" FontSize="14" Foreground="#FFD700" Margin="0,0,0,8">
                        <Run Text="Texture Slots - World "/>
                        <Run Text="{Binding Project.WorldNumber, Mode=OneWay}"/>
                        <Run Text=" (tex000 - tex255)"/>
                    </TextBlock>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SlotsGrid" ItemsSource="{Binding Project.Slots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="72" Height="90" Margin="2"
                                            Background="#2A2D32" BorderThickness="1"
                                            BorderBrush="#444" CornerRadius="3"
                                            Cursor="Hand" AllowDrop="True"
                                            MouseLeftButtonDown="Slot_MouseLeftButtonDown"
                                            MouseMove="Slot_MouseMove"
                                            DragEnter="Slot_DragEnter"
                                            Drop="Slot_Drop"
                                            Tag="{Binding}">
                                        <StackPanel>
                                            <Border Width="64" Height="64" Margin="4,4,4,0"
                                                    Background="#1A1B1E" BorderBrush="#333" BorderThickness="1">
                                                <Image Source="{Binding Image}" Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="9"
                                                       HorizontalAlignment="Center" Foreground="#888"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Width="6" Background="#333"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- RIGHT: Selected slot + Styles + Sky + Export -->
            <Border Grid.Column="4" Background="#252526" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Selected slot info -->
                    <Border Grid.Row="0" Background="#2A2D32" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Selected Slot" FontWeight="Bold" Foreground="#7AD7FF" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="64" Height="64" Background="#1A1B1E"
                                        BorderBrush="#FFD700" BorderThickness="2">
                                    <Image Source="{Binding SelectedSlot.Image}" Stretch="UniformToFill"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                </Border>
                                <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedSlot.DisplayName}" FontSize="14"/>
                                    <TextBlock Text="{Binding SelectedSlot.SourceFilePath}"
                                               Foreground="#888" FontSize="10" TextTrimming="CharacterEllipsis"
                                               MaxWidth="200"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Button Style="{StaticResource ActionBtn}" Content="Import"
                                                Click="ImportTexture_Click" Padding="8,3"/>
                                        <Button Style="{StaticResource ActionBtn}" Content="Clear"
                                                Click="ClearSlot_Click" Padding="8,3"/>
                                        <Button Style="{StaticResource ActionBtn}" Content="Edit Tile"
                                                Click="EditTile_Click" Padding="8,3"
                                                Background="#3D5A80" BorderBrush="#5A7AAA"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- TexType flags -->
                            <Border Background="#252526" CornerRadius="3" Padding="6" Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="Texture Properties (textype.txt)" Foreground="#9ECBFF"
                                               FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                                    <WrapPanel>
                                        <CheckBox Content="Transparent (T)" Foreground="White" FontSize="10" Margin="0,0,8,2"
                                                  IsChecked="{Binding SelectedSlot.Transparent, Mode=TwoWay}"
                                                  ToolTip="Black pixels are rendered as transparent"/>
                                        <CheckBox Content="Wrapping (W)" Foreground="White" FontSize="10" Margin="0,0,8,2"
                                                  IsChecked="{Binding SelectedSlot.Wrapping, Mode=TwoWay}"
                                                  ToolTip="Texture wraps at edges"/>
                                        <CheckBox Content="Additive Alpha (A)" Foreground="White" FontSize="10" Margin="0,0,8,2"
                                                  IsChecked="{Binding SelectedSlot.AdditiveAlpha, Mode=TwoWay}"
                                                  ToolTip="Additive alpha blending"/>
                                        <CheckBox Content="Illumination Map (I)" Foreground="White" FontSize="10" Margin="0,0,8,2"
                                                  IsChecked="{Binding SelectedSlot.IlluminationMap, Mode=TwoWay}"
                                                  ToolTip="The next texture page is the self-illumination map for this texture"/>
                                        <CheckBox Content="Self Illuminating (S)" Foreground="White" FontSize="10" Margin="0,0,8,2"
                                                  IsChecked="{Binding SelectedSlot.SelfIlluminating, Mode=TwoWay}"
                                                  ToolTip="Entire texture is self-illuminating (glows in the dark)"/>
                                        <CheckBox Content="Exclude Fadeout (F)" Foreground="White" FontSize="10" Margin="0,0,8,2"
                                                  IsChecked="{Binding SelectedSlot.ExcludeFadeout, Mode=TwoWay}"
                                                  ToolTip="Texture is excluded from distance fadeout"/>
                                        <CheckBox Content="Alpha Masked (D)" Foreground="White" FontSize="10" Margin="0,0,8,2"
                                                  IsChecked="{Binding SelectedSlot.AlphaMasked, Mode=TwoWay}"
                                                  ToolTip="Alpha masked rendering - second texture is solid"/>
                                        <CheckBox Content="Alpha Transparent (M)" Foreground="White" FontSize="10" Margin="0,0,8,2"
                                                  IsChecked="{Binding SelectedSlot.AlphaTransparent, Mode=TwoWay}"
                                                  ToolTip="Uses the texture's alpha channel for transparency (requires 32-bit TGA)"/>
                                    </WrapPanel>
                                    <TextBlock Foreground="#666" FontSize="9" Margin="0,2,0,0">
                                        <Run Text="Active flags: "/>
                                        <Run Text="{Binding SelectedSlot.FlagsSummary, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Sound Group -->
                            <Border Background="#252526" CornerRadius="3" Padding="6" Margin="0,6,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Footstep Sound:" Foreground="#9ECBFF"
                                               FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="CmbSoundGroup" Width="140"
                                              Background="#333" Foreground="White" FontSize="11"
                                              SelectionChanged="CmbSoundGroup_Changed">
                                        <ComboBoxItem Content="(none)" Tag="-1"/>
                                        <ComboBoxItem Content="forest" Tag="0"/>
                                        <ComboBoxItem Content="glass" Tag="1"/>
                                        <ComboBoxItem Content="grass" Tag="2"/>
                                        <ComboBoxItem Content="gravel" Tag="3"/>
                                        <ComboBoxItem Content="metal" Tag="4"/>
                                        <ComboBoxItem Content="road (default)" Tag="5"/>
                                        <ComboBoxItem Content="snow" Tag="6"/>
                                        <ComboBoxItem Content="tiles/rock/ice" Tag="7"/>
                                        <ComboBoxItem Content="water" Tag="8"/>
                                        <ComboBoxItem Content="wood" Tag="9"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#2A2D32" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="TMA Styles" FontWeight="Bold" Foreground="#7AD7FF" VerticalAlignment="Center"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Load TMA" Padding="8,2"
                                        Click="LoadTma_Click" Margin="8,0,0,0"
                                        Background="#2D4A6A" BorderBrush="#4A6A9A"
                                        ToolTip="Import styles from an existing .tma file"/>
                            </StackPanel>

                            <ListBox Grid.Row="1" x:Name="StylesList"
                                     ItemsSource="{Binding Project.Styles}"
                                     SelectedItem="{Binding SelectedStyle}"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0"
                                     MouseDoubleClick="StylesList_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                                            <TextBlock FontSize="10" Foreground="#888">
                                                <Run Text="{Binding Pieces.Count, Mode=OneWay}"/>
                                                <Run Text=" pieces"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Sky -->
                    <Border Grid.Row="2" Background="#2A2D32" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Sky Image (256x256)" FontWeight="Bold" Foreground="#7AD7FF"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Import"
                                        Click="ImportSky_Click" Padding="8,3" Margin="8,0,0,0"/>
                                <Button Style="{StaticResource ActionBtn}" Content="Clear"
                                        Click="ClearSky_Click" Padding="8,3" Margin="4,0,0,0"/>
                            </StackPanel>
                            <Border Width="128" Height="128" Background="#1A1B1E"
                                    BorderBrush="#555" BorderThickness="1"
                                    HorizontalAlignment="Left">
                                <Image Source="{Binding Project.SkyImage}" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Export -->
                    <Button Grid.Row="3" Style="{StaticResource ActionBtn}"
                            Content="Export World" Click="Export_Click"
                            Background="#2D5A2D" BorderBrush="#3D7A3D"
                            FontSize="14" FontWeight="Bold" Padding="12,8"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
