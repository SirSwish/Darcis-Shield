<Window x:Class="UrbanChaosStyleEditor.Views.NewWorldDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Texture Set" Width="340" Height="180"
        Background="#1E1F22"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <StackPanel Margin="16">
        <TextBlock Text="Enter a world number for the new texture set:" Foreground="#E0E0E0" Margin="0,0,0,8"/>
        <TextBlock Text="(Must be greater than 20 - worlds 1-20 are reserved)" Foreground="#888" FontSize="11" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="World Number:" Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtWorldNumber" Width="60" Background="#333" Foreground="White"
                     BorderBrush="#555" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                     FontSize="14" Text="21"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Create" Padding="16,6" Margin="0,0,8,0"
                    Background="#2D5A2D" Foreground="White" BorderBrush="#4A8A4A"
                    Click="Create_Click" IsDefault="True"/>
            <Button Content="Cancel" Padding="16,6"
                    Background="#3A3D42" Foreground="White" BorderBrush="#555"
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
