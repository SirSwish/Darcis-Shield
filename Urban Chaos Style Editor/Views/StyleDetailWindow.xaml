<Window x:Class="UrbanChaosStyleEditor.Views.StyleDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Style" Width="650" Height="520"
        Background="#1E1F22"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Style name -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Style Name:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtStyleName" Width="300" Background="#333" Foreground="White"
                     BorderBrush="#555" Padding="4,2" FontSize="14"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Column headers -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Slot" Foreground="#7AD7FF" FontWeight="SemiBold" FontSize="11"/>
            <TextBlock Grid.Column="1" Text="Preview" Foreground="#7AD7FF" FontWeight="SemiBold" FontSize="11"/>
            <TextBlock Grid.Column="2" Text="Tex #" Foreground="#7AD7FF" FontWeight="SemiBold" FontSize="11"/>
            <TextBlock Grid.Column="3" Text="Page" Foreground="#7AD7FF" FontWeight="SemiBold" FontSize="11"/>
            <TextBlock Grid.Column="4" Text="Tx" Foreground="#7AD7FF" FontWeight="SemiBold" FontSize="11"/>
            <TextBlock Grid.Column="5" Text="Ty" Foreground="#7AD7FF" FontWeight="SemiBold" FontSize="11"/>
            <TextBlock Grid.Column="6" Text="Flags" Foreground="#7AD7FF" FontWeight="SemiBold" FontSize="11"/>
        </Grid>

        <!-- 5 piece rows -->
        <StackPanel x:Name="PieceRows" Grid.Row="2"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Padding="20,6" Margin="0,0,8,0"
                    Background="#2D5A2D" Foreground="White" BorderBrush="#4A8A4A"
                    Click="Save_Click"/>
            <Button Content="Cancel" Padding="20,6"
                    Background="#3A3D42" Foreground="White" BorderBrush="#555"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
