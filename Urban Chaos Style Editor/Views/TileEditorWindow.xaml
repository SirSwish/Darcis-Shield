<Window x:Class="UrbanChaosStyleEditor.Views.TileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tile Editor" Width="750" Height="620"
        Background="#1E1F22"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="190"/>
        </Grid.ColumnDefinitions>

        <!-- Canvas area -->
        <Border Grid.Column="0" Background="#111" BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Background="#2A2D32" Padding="4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Zoom:" Foreground="#888" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Slider x:Name="ZoomSlider" Width="100" Minimum="1" Maximum="16" Value="8"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="ZoomSlider_ValueChanged"/>
                        <TextBlock x:Name="ZoomLabel" Text="8x" Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <Rectangle Width="1" Fill="#555" Margin="8,2"/>
                        <CheckBox x:Name="ChkGrid" Content="Grid" Foreground="White" IsChecked="True"
                                  VerticalAlignment="Center" Margin="4,0"
                                  Checked="ChkGrid_Changed" Unchecked="ChkGrid_Changed"/>
                        <CheckBox x:Name="ChkCheckerboard" Content="Alpha BG" Foreground="White" IsChecked="True"
                                  VerticalAlignment="Center" Margin="4,0"
                                  ToolTip="Show checkerboard background for transparent pixels"
                                  Checked="ChkGrid_Changed" Unchecked="ChkGrid_Changed"/>
                    </StackPanel>
                </Border>

                <!-- Pixel canvas -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Background="#111">
                    <Canvas x:Name="PixelCanvas"
                            ClipToBounds="True"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            MouseRightButtonDown="Canvas_MouseRightButtonDown"
                            MouseMove="Canvas_MouseMove"
                            MouseLeftButtonUp="Canvas_MouseLeftButtonUp"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right panel: tools + colour -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Preview -->
                <Border Background="#2A2D32" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Preview (1:1)" Foreground="#7AD7FF" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Border Width="64" Height="64" Background="#111" BorderBrush="#444" BorderThickness="1"
                            HorizontalAlignment="Left">
                            <Image x:Name="PreviewImage" Stretch="None"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Tool selection -->
                <Border Background="#2A2D32" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Tool" Foreground="#7AD7FF" FontWeight="Bold" Margin="0,0,0,4"/>
                        <RadioButton x:Name="ToolPencil" Content="Pencil" Foreground="White" IsChecked="True" Margin="0,2"
                                 GroupName="Tool"/>
                        <RadioButton x:Name="ToolEraser" Content="Eraser" Foreground="White" Margin="0,2"
                                 GroupName="Tool"/>
                        <RadioButton x:Name="ToolFill" Content="Fill" Foreground="White" Margin="0,2"
                                 GroupName="Tool"/>
                        <RadioButton x:Name="ToolPicker" Content="Color Picker" Foreground="White" Margin="0,2"
                                 GroupName="Tool"/>
                        <RadioButton x:Name="ToolAlphaRect" Content="Alpha Select" Foreground="#FFD700" Margin="0,2"
                                 GroupName="Tool" ToolTip="Drag a rectangle to set alpha on selected pixels"/>
                    </StackPanel>
                </Border>

                <!-- Alpha tool options (visible when Alpha Select is active) -->
                <Border x:Name="AlphaOptionsPanel" Background="#2A2D32" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Alpha" Foreground="#FFD700" FontWeight="Bold" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="A:" Foreground="#888" VerticalAlignment="Center" Width="16"/>
                            <Slider x:Name="SliderA" Width="100" Minimum="0" Maximum="255" Value="0"
                                ValueChanged="AlphaSlider_Changed"/>
                            <TextBlock x:Name="LblA" Text="0" Foreground="White" Width="28" Margin="4,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Drag on canvas to select pixels." Foreground="#888" FontSize="9" Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                        <TextBlock Text="0 = fully transparent" Foreground="#666" FontSize="9"/>
                        <TextBlock Text="255 = fully opaque" Foreground="#666" FontSize="9"/>
                        <Button Content="Set All Opaque" Padding="6,3" Margin="0,6,0,2"
                            Background="#3A3D42" Foreground="White" BorderBrush="#555"
                            Click="SetAllOpaque_Click" FontSize="10"/>
                        <Button Content="Set All Transparent" Padding="6,3" Margin="0,2,0,0"
                            Background="#3A3D42" Foreground="#FFD700" BorderBrush="#555"
                            Click="SetAllTransparent_Click" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Colour -->
                <Border Background="#2A2D32" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Color" Foreground="#7AD7FF" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Border x:Name="ColorPreviewBorder" Width="32" Height="32" Background="White"
                            BorderBrush="#888" BorderThickness="1" HorizontalAlignment="Left"
                            Margin="0,0,0,4" Cursor="Hand" MouseLeftButtonDown="ColorPreview_Click"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="R:" Foreground="#888" VerticalAlignment="Center" Width="16"/>
                            <Slider x:Name="SliderR" Width="100" Minimum="0" Maximum="255" Value="255"
                                ValueChanged="ColorSlider_Changed"/>
                            <TextBlock x:Name="LblR" Text="255" Foreground="White" Width="28" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="G:" Foreground="#888" VerticalAlignment="Center" Width="16"/>
                            <Slider x:Name="SliderG" Width="100" Minimum="0" Maximum="255" Value="255"
                                ValueChanged="ColorSlider_Changed"/>
                            <TextBlock x:Name="LblG" Text="255" Foreground="White" Width="28" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="B:" Foreground="#888" VerticalAlignment="Center" Width="16"/>
                            <Slider x:Name="SliderB" Width="100" Minimum="0" Maximum="255" Value="255"
                                ValueChanged="ColorSlider_Changed"/>
                            <TextBlock x:Name="LblB" Text="255" Foreground="White" Width="28" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Palette -->
                <Border Background="#2A2D32" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Palette" Foreground="#7AD7FF" FontWeight="Bold" Margin="0,0,0,4"/>
                        <WrapPanel x:Name="PalettePanel" Orientation="Horizontal"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Save" Padding="16,6" Margin="0,0,8,0"
                        Background="#2D5A2D" Foreground="White" BorderBrush="#4A8A4A"
                        Click="Save_Click"/>
                    <Button Content="Cancel" Padding="16,6"
                        Background="#3A3D42" Foreground="White" BorderBrush="#555"
                        Click="Cancel_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
